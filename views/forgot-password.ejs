<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>trackForward - Forgot Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet">
  <style>
    /* CSS Reset & Base Styles */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --primary: 0,0%,13.73%;
      --primary-hover: #3535d6;
      --foreground: #171717;
      --muted-foreground: #737373;
      --border: #e5e5e5;
      --background: #ffffff;
      --input-bg: #ffffff;
      --radius: 8px;
    }

    html, body {
      height: 100%;
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      color: var(--foreground);
      background-color: var(--background);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Layout Container */
    .container {
      display: flex;
      min-height: 100vh;
    }

    /* Left Panel - Branding */
    .left-panel {
      display: none;
      width: 50%;
      position: relative;
      overflow: hidden;
      background-color: var(--primary);
    }

    @media (min-width: 1024px) {
      .left-panel {
        display: flex;
      }
    }

    .left-content {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 100%;
      padding: 48px;
    }

    /* Logo */
    .logo {
      display: flex;
      align-items: center;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      background-color: #ffffff;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 12px;
    }

    .logo-icon-inner {
      width: 16px;
      height: 16px;
      background-color: var(--primary);
      border-radius: 4px;
    }

    .logo-text {
      font-size: 20px;
      font-weight: 600;
      color: #ffffff;
    }

    /* Hero Content */
    .hero-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-title {
      font-size: 36px;
      font-weight: 400;
      color: #ffffff;
      margin-bottom: 24px;
      line-height: 1.2;
    }

    .hero-description {
      font-size: 18px;
      color: rgba(255, 255, 255, 0.9);
      line-height: 1.6;
    }

    /* Footer */
    .left-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.7);
    }

    .privacy-link {
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      cursor: pointer;
      transition: color 0.2s ease;
    }

    .privacy-link:hover {
      color: rgba(255, 255, 255, 0.9);
    }

    /* Right Panel - Form */
    .right-panel {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px;
      background-color: #ffffff;
    }

    @media (min-width: 1024px) {
      .right-panel {
        width: 50%;
      }
    }

    .form-container {
      width: 100%;
      max-width: 400px;
      position: relative;
    }

    /* Mobile Logo */
    .mobile-logo {
      display: block;
      text-align: center;
      margin-bottom: 32px;
    }

    @media (min-width: 1024px) {
      .mobile-logo {
        display: none;
      }
    }

    .mobile-logo-icon {
      width: 32px;
      height: 32px;
      background-color: var(--primary);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 12px;
    }

    .mobile-logo-icon-inner {
      width: 16px;
      height: 16px;
      background-color: #ffffff;
      border-radius: 4px;
    }

    .mobile-logo-text {
      font-size: 20px;
      font-weight: 600;
      color: var(--foreground);
    }

    /* Back Button */
    .back-button {
      position: absolute;
      left: 0;
      top: -60px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: transparent;
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background-color 0.2s ease;
      opacity: 0;
      visibility: hidden;
      transform: translateX(-10px);
      transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease, background-color 0.2s ease;
    }

    .back-button.visible {
      opacity: 1;
      visibility: visible;
      transform: translateX(0);
    }

    .back-button:hover {
      background-color: #f5f5f5;
    }

    .back-button svg {
      width: 16px;
      height: 16px;
      color: var(--foreground);
    }

    /* Form Header */
    .form-header {
      text-align: center;
      margin-bottom: 24px;
    }

    .form-title {
      font-size: 30px;
      font-weight: 400;
      color: var(--foreground);
      margin-bottom: 8px;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .form-subtitle {
      font-size: 14px;
      color: var(--muted-foreground);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    /* View Container for Animations */
    .view-container {
      position: relative;
    }

    .view {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .view.fade-in {
      animation: fadeIn 0.3s ease forwards;
    }

    .view.fade-out {
      animation: fadeOut 0.2s ease forwards;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeOut {
      from {
        opacity: 1;
        transform: translateY(0);
      }
      to {
        opacity: 0;
        transform: translateY(-10px);
      }
    }

    /* Form Fields */
    .form-fields {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 16px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field-label {
      font-size: 14px;
      font-weight: 500;
      color: var(--foreground);
    }

    .field-input {
      height: 48px;
      width: 100%;
      padding: 0 16px;
      font-size: 14px;
      font-family: inherit;
      color: var(--foreground);
      background-color: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      outline: none;
      transition: border-color 0.2s ease;
    }

    .field-input::placeholder {
      color: var(--muted-foreground);
    }

    .field-input:focus {
      border-color: var(--primary);
    }

    /* Password Field */
    .password-field {
      position: relative;
    }

    .password-field .field-input {
      padding-right: 48px;
    }

    .password-toggle {
      position: absolute;
      right: 0;
      top: 0;
      height: 100%;
      width: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--muted-foreground);
      transition: color 0.2s ease;
    }

    .password-toggle:hover {
      color: var(--foreground);
    }

    .password-toggle svg {
      width: 16px;
      height: 16px;
    }

    /* Remember Me Row */
    .remember-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .remember-checkbox {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .remember-checkbox input {
      width: 16px;
      height: 16px;
      cursor: pointer;
      accent-color: var(--primary);
    }

    .remember-checkbox span {
      font-size: 14px;
      color: var(--muted-foreground);
    }

    .forgot-link {
      font-size: 14px;
      color: var(--primary);
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
      padding: 0;
      transition: opacity 0.2s ease;
    }

    .forgot-link:hover {
      opacity: 0.8;
    }

    /* Primary Button */
    .btn-primary {
      width: 100%;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      color: #ffffff;
      background-color: var(--primary);
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      transition: opacity 0.2s ease, transform 0.1s ease;
    }

    .btn-primary:hover {
      opacity: 0.9;
    }

    .btn-primary:active {
      transform: scale(0.99);
    }

    /* Separator */
    .separator {
      display: flex;
      align-items: center;
      margin: 24px 0;
    }

    .separator-line {
      flex: 1;
      height: 1px;
      background-color: var(--border);
    }

    .separator-text {
      padding: 0 8px;
      font-size: 12px;
      text-transform: uppercase;
      color: var(--muted-foreground);
      background-color: #ffffff;
    }

    /* Social Buttons */
    .social-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }

    .btn-social {
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 400;
      font-family: inherit;
      color: var(--foreground);
      background-color: #ffffff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: background-color 0.2s ease;
    }

    .btn-social:hover {
      background-color: #f9f9f9;
    }

    .btn-social svg {
      width: 20px;
      height: 20px;
    }

    /* Footer Links */
    .form-footer {
      text-align: center;
      font-size: 14px;
      color: var(--muted-foreground);
    }

    .form-footer button {
      font-size: 14px;
      font-weight: 500;
      color: var(--primary);
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
      padding: 0;
      transition: opacity 0.2s ease;
    }

    .form-footer button:hover {
      opacity: 0.8;
    }

    /* Animations for field appearance */
    .field-animate {
      animation: fieldFadeIn 0.3s ease forwards;
    }

    @keyframes fieldFadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Focus styles */
    .field-input:focus-visible {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 1px var(--primary);
    }

    /* Button focus */
    button:focus-visible {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Left Panel - Branding -->
    <div class="left-panel">
      <div class="left-content">
        <!-- Logo -->
        <div class="logo">
          <div class="logo-icon">
            <div class="logo-icon-inner"></div>
          </div>
          <span class="logo-text">.Jobtrack</span>
        </div>

        <!-- Hero Content -->
        <div class="hero-content">
          <h2 class="hero-title">Effortlessly manage job applications.</h2>
          <p class="hero-description">Log in to access your dashboard and manage your applications with ease.</p>
        </div>

        <!-- Footer -->
        <div class="left-footer">
          <span>Copyright &copy; 2026 Jobtrack (pty) ltd.</span>
          <a href="#" class="privacy-link">Privacy Policy</a>
        </div>
      </div>
    </div>

    <!-- Right Panel - Form -->
    <div class="right-panel">
      <div class="form-container">
        <!-- Back Button (shown on forgot password) -->
        <button class="back-button" id="backButton" aria-label="Go back">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
        </button>

        <!-- Mobile Logo -->
        <div class="mobile-logo">
          <div class="mobile-logo-icon">
            <div class="mobile-logo-icon-inner"></div>
          </div>
          <span class="mobile-logo-text">.Jobtrack</span>
        </div>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title" id="formTitle">Forgot your password?</h1>
          <p class="form-subtitle">Enter your email address and we'll send you a link to reset your password.</p>
            <% if (locals.error) { %>
                <p class="form-subtitle" style="color: red;"><%= error %></p>
            <% } %>
        </div>

        <div class="view-container">

          <!-- Forgot Password View -->
          <div class="view hidden" id="forgotView">
            <form id="forgotForm">
              <div class="form-fields">
                <div class="field-group">
                  <label class="field-label" for="forgotEmail">Email</label>
                  <input 
                    type="email" 
                    id="forgotEmail" 
                    class="field-input" 
                    placeholder="user@company.com"
                    autocomplete="email"
                  >
                </div>
              </div>

              <button type="submit" class="btn-primary" style="margin-top: 8px;">Send Reset Link</button>
            </form>

            <div class="form-footer" style="margin-top: 24px;">
              Remember Your Password? <a href="/auth/login" type="button" style="text-decoration: none;" id="backToLoginBtn">Back to Login.</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</body>
</html>
