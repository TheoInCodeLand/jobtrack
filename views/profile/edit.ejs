<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | trackForward</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --background: 0 0% 100%;
            --foreground: 222.2 84% 4.9%;
            --card: 0 0% 100%; 
            --card-foreground: 222.2 84% 4.9%;
            --primary: 0,0%,13.73%;
            --primary-foreground: 210 40% 98%;
            --secondary: 210 40% 96%;
            --secondary-foreground: 222.2 84% 4.9%;
            --muted: 210 40% 96%;
            --muted-foreground: 215.4 16.3% 46.9%;
            --border: 214.3 31.8% 91.4%;
            --input: 214.3 31.8% 91.4%;
            --ring: 0,0%,13.73%;
            --radius: 0.75rem;
            --sidebar-background: 0 0% 98%;
            --sidebar-foreground: 240 5.3% 26.1%;
            --sidebar-accent: 240 4.8% 95.9%;
            --sidebar-accent-foreground: 240 5.9% 10%;
            --sidebar-border: 220 13% 91%;
            --danger: 0 84.2% 60.2%;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: hsl(var(--background));
            color: hsl(var(--foreground));
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        .app-wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 16rem;
            height: 100vh;
            background-color: hsl(var(--sidebar-background));
            border-right: 1px solid hsl(var(--sidebar-border));
            display: flex;
            flex-direction: column;
            z-index: 40;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid hsl(var(--sidebar-border));
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: hsl(var(--sidebar-foreground));
        }

        .sidebar-logo-icon {
            width: 2rem;
            height: 2rem;
            background: hsl(var(--primary));
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .sidebar-logo-text {
            font-weight: 700;
            font-size: 1.125rem;
            letter-spacing: -0.025em;
        }

        .sidebar-content {
            flex: 1;
            padding: 1rem;
            overflow-y: auto;
        }

        .sidebar-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .sidebar-menu-button {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.625rem 0.75rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: hsl(var(--sidebar-foreground));
            text-decoration: none;
            border-radius: calc(var(--radius) - 2px);
            transition: background-color 0.15s, color 0.15s;
            border: none;
            background: transparent;
            cursor: pointer;
        }

        .sidebar-menu-button:hover {
            background-color: hsl(var(--sidebar-accent));
            color: hsl(var(--sidebar-accent-foreground));
        }

        .sidebar-menu-button.active {
            background-color: hsl(var(--sidebar-accent));
            color: hsl(var(--sidebar-accent-foreground));
            font-weight: 600;
        }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid hsl(var(--sidebar-border));
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            border-radius: calc(var(--radius) - 2px);
            background-color: hsl(var(--sidebar-accent) / 0.5);
        }

        .sidebar-user-avatar {
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: hsl(var(--primary));
            color: white;
            font-weight: 600;
            font-size: 0.875rem;
        }

        .main-content {
            flex: 1;
            margin-left: 16rem;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid hsl(var(--border));
            background-color: hsl(var(--background));
            position: sticky;
            top: 0;
            z-index: 30;
        }

        .page-content {
            flex: 1;
            padding: 1.5rem 2rem 2rem;
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-title {
            font-size: 1.875rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            color: hsl(var(--foreground));
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: hsl(var(--muted-foreground));
            font-size: 0.9375rem;
        }

        .card {
            border-radius: var(--radius);
            border: 1px solid hsl(var(--border));
            background-color: hsl(var(--card));
            color: hsl(var(--card-foreground));
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid hsl(var(--border));
            background-color: hsl(var(--muted) / 0.3);
        }

        .card-title {
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-content {
            padding: 1.5rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        label {
            font-size: 0.875rem;
            font-weight: 500;
            color: hsl(var(--foreground));
        }

        .required::after {
            content: ' *';
            color: hsl(var(--danger));
        }

        input[type="text"],
        input[type="email"],
        input[type="url"],
        input[type="tel"],
        input[type="number"],
        select,
        textarea {
            width: 100%;
            padding: 0.625rem 0.75rem;
            font-size: 0.875rem;
            border: 1px solid hsl(var(--input));
            border-radius: calc(var(--radius) - 2px);
            background-color: transparent;
            color: hsl(var(--foreground));
            transition: border-color 0.15s, box-shadow 0.15s;
            font-family: inherit;
        }

        input:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: hsl(var(--ring));
            box-shadow: 0 0 0 2px hsl(var(--ring) / 0.2);
        }

        textarea {
            resize: vertical;
            min-height: 120px;
        }

        .help-text {
            font-size: 0.75rem;
            color: hsl(var(--muted-foreground));
            margin-top: 0.25rem;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }

        .checkbox-group input[type="checkbox"] {
            width: 1.125rem;
            height: 1.125rem;
            accent-color: hsl(var(--primary));
            cursor: pointer;
        }

        .checkbox-group label {
            margin: 0;
            cursor: pointer;
            font-size: 0.875rem;
        }

        /* Tag Input Styling */
        .tag-input-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            padding: 0.5rem;
            border: 1px solid hsl(var(--input));
            border-radius: calc(var(--radius) - 2px);
            min-height: 42px;
            align-items: center;
        }

        .tag-input-container:focus-within {
            border-color: hsl(var(--ring));
            box-shadow: 0 0 0 2px hsl(var(--ring) / 0.2);
        }

        .tag {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.25rem 0.75rem;
            background-color: hsl(var(--primary) / 0.1);
            color: hsl(var(--primary));
            border-radius: 9999px;
            font-size: 0.8125rem;
            font-weight: 500;
        }

        .tag-remove {
            cursor: pointer;
            font-size: 1rem;
            line-height: 1;
            opacity: 0.7;
            transition: opacity 0.15s;
        }

        .tag-remove:hover {
            opacity: 1;
        }

        .tag-input {
            flex: 1;
            min-width: 120px;
            border: none;
            outline: none;
            padding: 0.25rem;
            font-size: 0.875rem;
            background: transparent;
        }

        /* Photo Upload */
        .photo-upload-section {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .photo-preview {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: hsl(var(--muted));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 600;
            color: hsl(var(--primary));
            border: 3px solid hsl(var(--border));
            overflow: hidden;
            position: relative;
        }

        .photo-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .photo-preview-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.75rem;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .photo-preview:hover .photo-preview-overlay {
            opacity: 1;
        }

        .upload-controls {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .file-input-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
        }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.625rem 1rem;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: calc(var(--radius) - 2px);
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            border: none;
            font-family: inherit;
        }

        .btn:active {
            transform: scale(0.98);
        }

        .btn-primary {
            background-color: hsl(var(--primary));
            color: hsl(var(--primary-foreground));
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-secondary {
            background-color: hsl(var(--secondary));
            color: hsl(var(--secondary-foreground));
            border: 1px solid hsl(var(--border));
        }

        .btn-secondary:hover {
            background-color: hsl(var(--muted));
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid hsl(var(--input));
            color: hsl(var(--foreground));
        }

        .btn-outline:hover {
            background-color: hsl(var(--accent));
        }

        .btn-sm {
            padding: 0.5rem 0.75rem;
            font-size: 0.8125rem;
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid hsl(var(--border));
        }

        .alert {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem 1.25rem;
            border-radius: var(--radius);
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .alert-error {
            background-color: hsl(0 84.2% 60.2% / 0.1);
            border: 1px solid hsl(0 84.2% 60.2% / 0.2);
            color: hsl(0 84.2% 60.2%);
        }

        .section-divider {
            height: 1px;
            background-color: hsl(var(--border));
            margin: 1.5rem 0;
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }
            
            .sidebar {
                transform: translateX(-100%);
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body>
    <div class="app-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <a href="/applications/dashboard" class="sidebar-logo">
                    <div class="sidebar-logo-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="14" x="2" y="7" rx="2" ry="2"/>
                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                        </svg>
                    </div>
                    <span class="sidebar-logo-text">trackForward</span>
                </a>
            </div>
            <nav class="sidebar-content">
                <ul class="sidebar-menu">
                    <li>
                        <a href="/applications/dashboard" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="7" height="9" x="3" y="3" rx="1"/>
                                <rect width="7" height="5" x="14" y="3" rx="1"/>
                                <rect width="7" height="9" x="14" y="12" rx="1"/>
                                <rect width="7" height="5" x="3" y="16" rx="1"/>
                            </svg>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a href="/smart-ats" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5"/>
                                <path d="M2 12l10 5 10-5"/>
                            </svg>
                            <span>Smart ATS</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/profile" class="sidebar-menu-button active">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span>Profile</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/settings" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        <%= user.charAt(0).toUpperCase() %>
                    </div>
                    <div style="display: flex; flex-direction: column; min-width: 0;">
                        <span style="font-size: 0.875rem; font-weight: 600; color: hsl(var(--sidebar-foreground)); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= user %></span>
                        <span style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">Job Seeker</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <a href="/user/profile" class="btn btn-secondary btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                            <path d="m15 18-6-6 6-6"/>
                        </svg>
                        Back to Profile
                    </a>
                </div>
                <div>
                    <button type="submit" form="profileForm" class="btn btn-primary">Save Changes</button>
                </div>
            </header>

            <!-- Page Content -->
            <div class="page-content">
                <div class="page-header">
                    <h1 class="page-title">Edit Profile</h1>
                    <p class="page-subtitle">Update your professional information and preferences</p>
                </div>

                <% if (error) { %>
                    <div class="alert alert-error">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" x2="9" y1="9" y2="15"/>
                            <line x1="9" x2="15" y1="9" y2="15"/>
                        </svg>
                        <%= error %>
                    </div>
                <% } %>

                <!-- Photo Upload Card -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                                <circle cx="9" cy="9" r="2"/>
                                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                            </svg>
                            Profile Photo
                        </h2>
                    </div>
                    <div class="card-content">
                        <form action="/user/profile/upload-photo" method="POST" enctype="multipart/form-data" id="photoForm">
                            <div class="photo-upload-section">
                                <div class="photo-preview" id="photoPreview">
                                    <% if (profile.profile_picture) { %>
                                        <img src="<%= profile.profile_picture %>" alt="Current photo">
                                    <% } else { %>
                                        <%= profile.full_name.charAt(0).toUpperCase() %>
                                    <% } %>
                                    <div class="photo-preview-overlay">Change</div>
                                </div>
                                <div class="upload-controls">
                                    <div class="file-input-wrapper">
                                        <input type="file" name="profile_picture" id="photoInput" accept="image/*" required>
                                        <label for="photoInput" class="btn btn-outline btn-sm">Choose New Photo</label>
                                    </div>
                                    <p class="help-text">JPG, PNG or WebP. Max 5MB.</p>
                                    <button type="submit" class="btn btn-primary btn-sm" id="uploadBtn" style="display: none; margin-top: 0.5rem;">
                                        Upload Photo
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Main Profile Form -->
                <form action="/user/profile/update" method="POST" id="profileForm">
                    <!-- Basic Information -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                Basic Information
                            </h2>
                        </div>
                        <div class="card-content">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="full_name" class="required">Full Name</label>
                                    <input type="text" id="full_name" name="full_name" value="<%= profile.full_name %>" required>
                                </div>

                                <div class="form-group">
                                    <label for="email">Email</label>
                                    <input type="email" id="email" value="<%= profile.email %>" disabled style="background-color: hsl(var(--muted) / 0.5);">
                                    <p class="help-text">Email cannot be changed</p>
                                </div>

                                <div class="form-group">
                                    <label for="phone">Phone Number</label>
                                    <input type="tel" id="phone" name="phone" value="<%= profile.phone || '' %>" placeholder="+27 12 345 6789">
                                </div>

                                <div class="form-group">
                                    <label for="location">Current Location</label>
                                    <input type="text" id="location" name="location" value="<%= profile.location || '' %>" placeholder="Johannesburg, South Africa">
                                </div>

                                <div class="form-group">
                                    <label for="timezone">Timezone</label>
                                    <select id="timezone" name="timezone">
                                        <option value="Africa/Johannesburg" <%= profile.timezone === 'Africa/Johannesburg' ? 'selected' : '' %>>Johannesburg (SAST)</option>
                                        <option value="Africa/Lagos" <%= profile.timezone === 'Africa/Lagos' ? 'selected' : '' %>>Lagos (WAT)</option>
                                        <option value="Europe/London" <%= profile.timezone === 'Europe/London' ? 'selected' : '' %>>London (GMT/BST)</option>
                                        <option value="America/New_York" <%= profile.timezone === 'America/New_York' ? 'selected' : '' %>>New York (ET)</option>
                                        <option value="America/Los_Angeles" <%= profile.timezone === 'America/Los_Angeles' ? 'selected' : '' %>>Los Angeles (PT)</option>
                                        <option value="Asia/Dubai" <%= profile.timezone === 'Asia/Dubai' ? 'selected' : '' %>>Dubai (GST)</option>
                                    </select>
                                </div>

                                <div class="form-group full-width">
                                    <label for="bio">Professional Summary</label>
                                    <textarea id="bio" name="bio" placeholder="Tell us about your professional background, achievements, and career aspirations..."><%= profile.bio || '' %></textarea>
                                    <p class="help-text">This will be visible on your public profile if you choose to make it public.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Professional Details -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect width="20" height="14" x="2" y="7" rx="2" ry="2"/>
                                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                                </svg>
                                Professional Details
                            </h2>
                        </div>
                        <div class="card-content">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="current_job_title">Current Job Title</label>
                                    <input type="text" id="current_job_title" name="current_job_title" value="<%= profile.current_job_title || '' %>" placeholder="Senior Software Engineer">
                                </div>

                                <div class="form-group">
                                    <label for="current_employer">Current Employer</label>
                                    <input type="text" id="current_employer" name="current_employer" value="<%= profile.current_employer || '' %>" placeholder="Company Name">
                                </div>

                                <div class="form-group">
                                    <label for="years_of_experience">Years of Experience</label>
                                    <input type="number" id="years_of_experience" name="years_of_experience" value="<%= profile.years_of_experience || '' %>" min="0" max="50">
                                </div>

                                <div class="form-group">
                                    <label for="career_goal">Career Goal</label>
                                    <input type="text" id="career_goal" name="career_goal" value="<%= profile.career_goal || '' %>" placeholder="e.g., Full Stack Developer">
                                </div>

                                <div class="form-group">
                                    <label for="institution">Institution</label>
                                    <input type="text" id="institution" name="institution" value="<%= profile.institution || '' %>" placeholder="University of Mpumalanga">
                                </div>

                                <div class="form-group">
                                    <label for="graduation_year">Graduation Year</label>
                                    <input type="number" id="graduation_year" name="graduation_year" value="<%= profile.graduation_year || '' %>" min="1970" max="2030">
                                </div>
                            </div>

                            <div class="section-divider"></div>

                            <!-- Skills -->
                            <div class="form-group full-width" style="margin-bottom: 1.5rem;">
                                <label>Skills</label>
                                <div class="tag-input-container" id="skillsContainer">
                                    <% if (profile.skills && profile.skills.length > 0) { %>
                                        <% profile.skills.forEach(skill => { %>
                                            <span class="tag"><%= skill %><span class="tag-remove" onclick="removeTag(this, 'skills')">×</span></span>
                                        <% }) %>
                                    <% } %>
                                    <input type="text" class="tag-input" id="skillsInput" placeholder="Add a skill and press Enter">
                                </div>
                                <input type="hidden" name="skills" id="skillsHidden" value="<%= profile.skills ? profile.skills.join(',') : '' %>">
                                <p class="help-text">Press Enter to add multiple skills</p>
                            </div>

                            <!-- Languages -->
                            <div class="form-group full-width">
                                <label>Languages</label>
                                <div class="tag-input-container" id="languagesContainer">
                                    <% if (profile.languages && profile.languages.length > 0) { %>
                                        <% profile.languages.forEach(lang => { %>
                                            <span class="tag"><%= lang %><span class="tag-remove" onclick="removeTag(this, 'languages')">×</span></span>
                                        <% }) %>
                                    <% } %>
                                    <input type="text" class="tag-input" id="languagesInput" placeholder="Add a language and press Enter">
                                </div>
                                <input type="hidden" name="languages" id="languagesHidden" value="<%= profile.languages ? profile.languages.join(',') : '' %>">
                            </div>
                        </div>
                    </div>

                    <!-- Online Presence -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                </svg>
                                Online Presence
                            </h2>
                        </div>
                        <div class="card-content">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="linkedin_url">LinkedIn URL</label>
                                    <input type="url" id="linkedin_url" name="linkedin_url" value="<%= profile.linkedin_url || '' %>" placeholder="https://linkedin.com/in/username">
                                </div>

                                <div class="form-group">
                                    <label for="github_url">GitHub URL</label>
                                    <input type="url" id="github_url" name="github_url" value="<%= profile.github_url || '' %>" placeholder="https://github.com/username">
                                </div>

                                <div class="form-group full-width">
                                    <label for="portfolio_url">Portfolio Website</label>
                                    <input type="url" id="portfolio_url" name="portfolio_url" value="<%= profile.portfolio_url || '' %>" placeholder="https://myportfolio.com">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Job Preferences -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                                    <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                                    <path d="M4 22h16"/>
                                    <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                                    <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                                    <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
                                </svg>
                                Job Preferences
                            </h2>
                        </div>
                        <div class="card-content">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="preferred_work_arrangement">Preferred Work Arrangement</label>
                                    <select id="preferred_work_arrangement" name="preferred_work_arrangement">
                                        <option value="">Select...</option>
                                        <option value="remote" <%= profile.preferred_work_arrangement === 'remote' ? 'selected' : '' %>>Remote Only</option>
                                        <option value="hybrid" <%= profile.preferred_work_arrangement === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
                                        <option value="onsite" <%= profile.preferred_work_arrangement === 'onsite' ? 'selected' : '' %>>On-site</option>
                                        <option value="flexible" <%= profile.preferred_work_arrangement === 'flexible' ? 'selected' : '' %>>Flexible</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="desired_salary_min">Minimum Salary (R)</label>
                                    <input type="number" id="desired_salary_min" name="desired_salary_min" value="<%= profile.desired_salary_min || '' %>" placeholder="500000">
                                </div>

                                <div class="form-group">
                                    <label for="desired_salary_max">Maximum Salary (R)</label>
                                    <input type="number" id="desired_salary_max" name="desired_salary_max" value="<%= profile.desired_salary_max || '' %>" placeholder="800000">
                                </div>

                                <div class="form-group full-width">
                                    <label>Preferred Locations</label>
                                    <div class="tag-input-container" id="locationsContainer">
                                        <% if (profile.preferred_locations && profile.preferred_locations.length > 0) { %>
                                            <% profile.preferred_locations.forEach(loc => { %>
                                                <span class="tag"><%= loc %><span class="tag-remove" onclick="removeTag(this, 'locations')">×</span></span>
                                            <% }) %>
                                        <% } %>
                                        <input type="text" class="tag-input" id="locationsInput" placeholder="Add a location and press Enter">
                                    </div>
                                    <input type="hidden" name="preferred_locations" id="locationsHidden" value="<%= profile.preferred_locations ? profile.preferred_locations.join(',') : '' %>">
                                    <p class="help-text">Enter cities or "Remote" separated by Enter</p>
                                </div>

                                <div class="form-group full-width">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="willing_to_relocate" name="willing_to_relocate" <%= profile.willing_to_relocate ? 'checked' : '' %>>
                                        <label for="willing_to_relocate">Willing to relocate for the right opportunity</label>
                                    </div>
                                </div>

                                <div class="form-group full-width">
                                    <div class="checkbox-group">
                                        <input type="checkbox" id="open_to_work" name="open_to_work" <%= profile.open_to_work ? 'checked' : '' %>>
                                        <label for="open_to_work">Open to work (visible on profile)</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="/user/profile" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script>
        // Tag Input Management
        function setupTagInput(inputId, containerId, hiddenId) {
            const input = document.getElementById(inputId);
            const container = document.getElementById(containerId);
            const hidden = document.getElementById(hiddenId);

            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const value = this.value.trim();
                    if (value) {
                        addTag(value, container, input, hidden);
                        this.value = '';
                        updateHidden(container, hidden);
                    }
                }
            });
        }

        function addTag(text, container, input, hidden) {
            // Check if tag already exists
            const existingTags = Array.from(container.querySelectorAll('.tag')).map(tag => 
                tag.childNodes[0].textContent.trim()
            );
            
            if (existingTags.includes(text)) return;

            const tag = document.createElement('span');
            tag.className = 'tag';
            const hiddenId = hidden.id;
            const type = hiddenId.replace('Hidden', '');
            tag.innerHTML = `${text}<span class="tag-remove" onclick="removeTag(this, '${type}')">×</span>`;
            container.insertBefore(tag, input);
        }

        function removeTag(element, type) {
            element.parentElement.remove();
            const hiddenId = type + 'Hidden';
            const containerId = type + 'Container';
            updateHidden(document.getElementById(containerId), document.getElementById(hiddenId));
        }

        function updateHidden(container, hidden) {
            const tags = Array.from(container.querySelectorAll('.tag')).map(tag => 
                tag.childNodes[0].textContent.trim()
            );
            hidden.value = tags.join(',');
        }

        // Setup all tag inputs
        setupTagInput('skillsInput', 'skillsContainer', 'skillsHidden');
        setupTagInput('languagesInput', 'languagesContainer', 'languagesHidden');
        setupTagInput('locationsInput', 'locationsContainer', 'locationsHidden');

        // Photo Upload Preview
        const photoInput = document.getElementById('photoInput');
        const uploadBtn = document.getElementById('uploadBtn');
        const photoPreview = document.getElementById('photoPreview');

        photoInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                uploadBtn.style.display = 'inline-flex';
                
                // Preview
                const reader = new FileReader();
                reader.onload = function(e) {
                    photoPreview.innerHTML = `<img src="${e.target.result}" alt="Preview"><div class="photo-preview-overlay">Change</div>`;
                };
                reader.readAsDataURL(this.files[0]);
            }
        });

        // Form submission validation
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            // Update all hidden fields before submit
            updateHidden(document.getElementById('skillsContainer'), document.getElementById('skillsHidden'));
            updateHidden(document.getElementById('languagesContainer'), document.getElementById('languagesHidden'));
            updateHidden(document.getElementById('locationsContainer'), document.getElementById('locationsHidden'));
        });
    </script>
</body>
</html>