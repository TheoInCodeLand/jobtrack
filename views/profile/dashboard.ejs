<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | trackForward</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Include the same CSS variables and base styles from your dashboard */
        :root {
            --background: 0 0% 100%;
            --foreground: 222.2 84% 4.9%;
            --card: 0 0% 100%;
            --card-foreground: 222.2 84% 4.9%;
            --primary: 0,0%,13.73%;
            --primary-foreground: 210 40% 98%;
            --secondary: 210 40% 96%;
            --secondary-foreground: 222.2 84% 4.9%;
            --muted: 210 40% 96%;
            --muted-foreground: 215.4 16.3% 46.9%;
            --border: 214.3 31.8% 91.4%;
            --input: 214.3 31.8% 91.4%;
            --ring: 0,0%,13.73%;
            --radius: 0.75rem;
            --sidebar-background: 0 0% 98%;
            --sidebar-foreground: 240 5.3% 26.1%;
            --sidebar-accent: 240 4.8% 95.9%;
            --sidebar-accent-foreground: 240 5.9% 10%;
            --sidebar-border: 220 13% 91%;
            --success: 142 76% 36%;
            --warning: 45 93% 47%;
            --danger: 0 84.2% 60.2%;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: hsl(var(--background));
            color: hsl(var(--foreground));
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        /* Layout - Same as Dashboard */
        .app-wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 16rem;
            height: 100vh;
            background-color: hsl(var(--sidebar-background));
            border-right: 1px solid hsl(var(--sidebar-border));
            display: flex;
            flex-direction: column;
            z-index: 40;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid hsl(var(--sidebar-border));
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: hsl(var(--sidebar-foreground));
        }

        .sidebar-logo-icon {
            width: 2rem;
            height: 2rem;
            background: hsl(var(--primary));
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .sidebar-logo-text {
            font-weight: 700;
            font-size: 1.125rem;
            letter-spacing: -0.025em;
        }

        .sidebar-content {
            flex: 1;
            padding: 1rem;
            overflow-y: auto;
        }

        .sidebar-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .sidebar-menu-button {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.625rem 0.75rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: hsl(var(--sidebar-foreground));
            text-decoration: none;
            border-radius: calc(var(--radius) - 2px);
            transition: background-color 0.15s, color 0.15s;
            border: none;
            background: transparent;
            cursor: pointer;
        }

        .sidebar-menu-button:hover {
            background-color: hsl(var(--sidebar-accent));
            color: hsl(var(--sidebar-accent-foreground));
        }

        .sidebar-menu-button.active {
            background-color: hsl(var(--sidebar-accent));
            color: hsl(var(--sidebar-accent-foreground));
            font-weight: 600;
        }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid hsl(var(--sidebar-border));
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            border-radius: calc(var(--radius) - 2px);
            background-color: hsl(var(--sidebar-accent) / 0.5);
        }

        .sidebar-user-avatar {
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: hsl(var(--primary));
            color: white;
            font-weight: 600;
            font-size: 0.875rem;
        }

        .main-content {
            flex: 1;
            margin-left: 16rem;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid hsl(var(--border));
            background-color: hsl(var(--background));
            position: sticky;
            top: 0;
            z-index: 30;
        }

        .page-content {
            flex: 1;
            padding: 1.5rem 2rem 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            max-width: 1200px;
        }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .page-title {
            font-size: 1.875rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            color: hsl(var(--foreground));
        }

        /* Profile Specific Styles */
        .profile-header-card {
            background: hsl(var(--primary));
            border-radius: var(--radius);
            padding: 2rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .profile-header-content {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .profile-avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: hsl(var(--primary));
            font-weight: 700;
            border: 4px solid rgba(255,255,255,0.3);
            overflow: hidden;
        }

        .profile-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-info h1 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }

        .profile-info p {
            opacity: 0.9;
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }

        .profile-meta {
            display: flex;
            gap: 1rem;
            font-size: 0.875rem;
            opacity: 0.9;
        }

        .profile-meta span {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .open-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            background: rgba(255,255,255,0.2);
            padding: 0.375rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 0.5rem;
        }

        .completion-badge {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            text-align: center;
        }

        .completion-percent {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .completion-label {
            font-size: 0.75rem;
            opacity: 0.9;
        }

        /* Cards */
        .card {
            border-radius: var(--radius);
            border: 1px solid hsl(var(--border));
            background-color: hsl(var(--card));
            color: hsl(var(--card-foreground));
            overflow: hidden;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid hsl(var(--border));
        }

        .card-title {
            font-size: 1.125rem;
            font-weight: 600;
        }

        .card-content {
            padding: 1.5rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: var(--radius);
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            border: none;
        }

        .btn-primary {
            background-color: hsl(var(--primary));
            color: hsl(var(--primary-foreground));
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid hsl(var(--input));
            color: hsl(var(--foreground));
        }

        .btn-outline:hover {
            background-color: hsl(var(--accent));
        }

        .btn-ghost {
            background: transparent;
            color: hsl(var(--foreground));
        }

        .btn-ghost:hover {
            background-color: hsl(var(--accent));
        }

        .btn-sm {
            padding: 0.25rem 0.75rem;
            font-size: 0.875rem;
        }

        /* Grid Layouts */
        .profile-grid {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 1.5rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .stat-card {
            background: hsl(var(--muted));
            padding: 1.25rem;
            border-radius: calc(var(--radius) - 2px);
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: hsl(var(--foreground));
        }

        .stat-label {
            font-size: 0.75rem;
            color: hsl(var(--muted-foreground));
            margin-top: 0.25rem;
        }

        .info-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .info-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: hsl(var(--muted-foreground));
            font-weight: 500;
        }

        .info-value {
            font-size: 0.9375rem;
            color: hsl(var(--foreground));
            font-weight: 500;
        }

        .skill-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .skill-tag {
            background: hsl(var(--primary) / 0.1);
            color: hsl(var(--primary));
            padding: 0.375rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .social-links {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .social-link {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: var(--radius);
            background: hsl(var(--muted));
            color: hsl(var(--muted-foreground));
            text-decoration: none;
            transition: all 0.2s;
        }

        .social-link:hover {
            background: hsl(var(--primary));
            color: white;
        }

        .alert {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem 1.25rem;
            border-radius: var(--radius);
            border: 1px solid hsl(var(--border));
            background-color: hsl(var(--background));
            font-size: 0.875rem;
        }

        .alert-success {
            background-color: hsl(142 76% 36% / 0.1);
            border-color: hsl(142 76% 36% / 0.2);
            color: hsl(142 76% 36%);
        }

        /* Responsive */
        @media (max-width: 968px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
            
            .main-content {
                margin-left: 0;
            }
            
            .sidebar {
                transform: translateX(-100%);
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
        }

        @media (max-width: 640px) {
            .profile-header-content {
                flex-direction: column;
                text-align: center;
            }
            
            .completion-badge {
                position: relative;
                top: auto;
                right: auto;
                margin-top: 1rem;
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="app-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <a href="/applications/dashboard" class="sidebar-logo">
                    <div class="sidebar-logo-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <span class="sidebar-logo-text">trackForward</span>
                </a>
            </div>
            <nav class="sidebar-content">
                <ul class="sidebar-menu">
                    <li>
                        <a href="/applications/dashboard" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a href="/smart-ats" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                            <span>Smart ATS</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/profile" class="sidebar-menu-button active">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Profile</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/settings" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        <%= user.charAt(0).toUpperCase() %>
                    </div>
                    <div style="display: flex; flex-direction: column; min-width: 0;">
                        <span style="font-size: 0.875rem; font-weight: 600; color: hsl(var(--sidebar-foreground)); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= user %></span>
                        <span style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">Job Seeker</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <h1 style="font-size: 1.25rem; font-weight: 700;">My Profile</h1>
                </div>
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <a href="/user/profile/edit" class="btn btn-primary">Edit Profile</a>
                </div>
            </header>

            <!-- Page Content -->
            <div class="page-content">
                <% if (success) { %>
                    <div class="alert alert-success">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <%= success %>
                    </div>
                <% } %>

                <!-- Profile Header -->
                <div class="profile-header-card">
                    <div class="profile-header-content">
                        <div class="profile-avatar-large">
                            <% if (profile.profile_picture) { %>
                                <img src="<%= profile.profile_picture %>" alt="<%= profile.full_name %>">
                            <% } else { %>
                                <%= profile.full_name.charAt(0).toUpperCase() %>
                            <% } %>
                        </div>
                        <div class="profile-info">
                            <h1><%= profile.full_name %></h1>
                            <p><%= profile.current_job_title || 'Job Seeker' %><% if (profile.current_employer) { %> at <%= profile.current_employer %><% } %></p>
                            <div class="profile-meta">
                                <span>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                    <%= profile.location || 'Location not set' %>
                                </span>
                                <span>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                                    <%= profile.years_of_experience || 0 %> years exp
                                </span>
                            </div>
                            <% if (profile.open_to_work) { %>
                                <div class="open-badge">
                                    <span style="width: 8px; height: 8px; background: #10B981; border-radius: 50%;"></span>
                                    Open to Work
                                </div>
                            <% } %>
                        </div>
                    </div>
                    <div class="completion-badge">
                        <div class="completion-percent"><%= profileCompletion %>%</div>
                        <div class="completion-label">Complete</div>
                    </div>
                </div>

                <!-- Profile Grid -->
                <div class="profile-grid">
                    <!-- Left Column -->
                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                        <!-- Stats -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Application Stats</h3>
                            </div>
                            <div class="card-content">
                                <div class="stats-grid">
                                    <div class="stat-card">
                                        <div class="stat-value"><%= stats.total_apps || 0 %></div>
                                        <div class="stat-label">Applications</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-value" style="color: hsl(var(--success));"><%= stats.offers || 0 %></div>
                                        <div class="stat-label">Offers</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-value" style="color: hsl(var(--primary));"><%= stats.interviews || 0 %></div>
                                        <div class="stat-label">Interviews</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-value"><%= stats.avg_response ? Math.round(stats.avg_response) : '-' %></div>
                                        <div class="stat-label">Avg Response</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Info -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Contact</h3>
                            </div>
                            <div class="card-content">
                                <div class="info-list">
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value"><%= profile.email %></span>
                                    </div>
                                    <% if (profile.phone) { %>
                                        <div class="info-item">
                                            <span class="info-label">Phone</span>
                                            <span class="info-value"><%= profile.phone %></span>
                                        </div>
                                    <% } %>
                                    <div class="info-item">
                                        <span class="info-label">Timezone</span>
                                        <span class="info-value"><%= profile.timezone %></span>
                                    </div>
                                </div>
                                
                                <% if (profile.linkedin_url || profile.github_url || profile.portfolio_url) { %>
                                    <div class="social-links">
                                        <% if (profile.linkedin_url) { %>
                                            <a href="<%= profile.linkedin_url %>" target="_blank" class="social-link" title="LinkedIn">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                            </a>
                                        <% } %>
                                        <% if (profile.github_url) { %>
                                            <a href="<%= profile.github_url %>" target="_blank" class="social-link" title="GitHub">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                                            </a>
                                        <% } %>
                                        <% if (profile.portfolio_url) { %>
                                            <a href="<%= profile.portfolio_url %>" target="_blank" class="social-link" title="Portfolio">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                                            </a>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                        <!-- About -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">About</h3>
                            </div>
                            <div class="card-content">
                                <% if (profile.bio) { %>
                                    <p style="line-height: 1.7; color: hsl(var(--foreground));"><%= profile.bio %></p>
                                <% } else { %>
                                    <p style="color: hsl(var(--muted-foreground)); font-style: italic;">No bio added yet. Tell us about your professional background and career aspirations.</p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Skills -->
                        <% if (profile.skills && profile.skills.length > 0) { %>
                            <div class="card">
                                <div class="card-header">
                                    <h3 class="card-title">Skills</h3>
                                </div>
                                <div class="card-content">
                                    <div class="skill-tags">
                                        <% profile.skills.forEach(skill => { %>
                                            <span class="skill-tag"><%= skill %></span>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <!-- Professional Details -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Professional Details</h3>
                            </div>
                            <div class="card-content">
                                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
                                    <div class="info-item">
                                        <span class="info-label">Institution</span>
                                        <span class="info-value"><%= profile.institution || 'Not specified' %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Graduation Year</span>
                                        <span class="info-value"><%= profile.graduation_year || 'Not specified' %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Career Goal</span>
                                        <span class="info-value"><%= profile.career_goal || 'Not specified' %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Preferred Work</span>
                                        <span class="info-value">
                                            <%= profile.preferred_work_arrangement ? profile.preferred_work_arrangement.charAt(0).toUpperCase() + profile.preferred_work_arrangement.slice(1) : 'Not specified' %>
                                        </span>
                                    </div>
                                    <% if (profile.desired_salary_min && profile.desired_salary_max) { %>
                                        <div class="info-item">
                                            <span class="info-label">Expected Salary</span>
                                            <span class="info-value">R<%= profile.desired_salary_min.toLocaleString() %> - R<%= profile.desired_salary_max.toLocaleString() %></span>
                                        </div>
                                    <% } %>
                                    <div class="info-item">
                                        <span class="info-label">Willing to Relocate</span>
                                        <span class="info-value"><%= profile.willing_to_relocate ? 'Yes' : 'No' %></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Preferred Locations -->
                        <% if (profile.preferred_locations && profile.preferred_locations.length > 0) { %>
                            <div class="card">
                                <div class="card-header">
                                    <h3 class="card-title">Preferred Locations</h3>
                                </div>
                                <div class="card-content">
                                    <div class="skill-tags">
                                        <% profile.preferred_locations.forEach(loc => { %>
                                            <span class="skill-tag"><%= loc %></span>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>