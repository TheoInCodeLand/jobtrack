                                <i class="bi bi-save"></i> Save Application
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

        <script>
        // Mobile sidebar toggle
        const mobileToggle = document.getElementById('mobileToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        if (mobileToggle) {
            mobileToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('show');
            });
        }
        if (overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            });
        }

        // User dropdown
        const userBtn = document.getElementById('userBtn');
        const userDropdown = document.getElementById('userDropdown');
        if (userBtn && userDropdown) {
            userBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                userDropdown.style.display = userDropdown.style.display === 'block' ? 'none' : 'block';
            });
            document.addEventListener('click', () => {
                userDropdown.style.display = 'none';
            });
        }

        // Toggle functions
        function toggleOtherMethod() {
            const select = document.getElementById('app_method');
            const container = document.getElementById('otherMethodContainer');
            container.style.display = select.value === 'Other' ? 'block' : 'none';
        }

        function toggleReferralDetails() {
            const check = document.getElementById('referralCheck');
            const details = document.getElementById('referralDetails');
            details.classList.toggle('show', check.checked);
        }

        function toggleAssessmentType() {
            const check = document.getElementById('assessmentCheck');
            const container = document.getElementById('assessmentTypeContainer');
            container.classList.toggle('show', check.checked);
        }

        // File upload handling
        function handleFileSelect(input) {
            const label = document.getElementById('fileUploadLabel');
            const fileNameDiv = document.getElementById('fileName');
            
            if (input.files && input.files[0]) {
                label.classList.add('has-file');
                fileNameDiv.style.display = 'block';
                fileNameDiv.querySelector('span').textContent = input.files[0].name;
            } else {
                label.classList.remove('has-file');
                fileNameDiv.style.display = 'none';
            }
        }

        // Tags input handling
        function setupTagsInput(containerId, inputId, hiddenId) {
            const container = document.getElementById(containerId);
            const input = document.getElementById(inputId);
            const hidden = document.getElementById(hiddenId);
            const tags = new Set();

            function updateHidden() {
                hidden.value = Array.from(tags).join(',');
            }

            function createTag(text) {
                const tag = document.createElement('span');
                tag.className = 'tag';
                tag.innerHTML = `${text} <i class="bi bi-x-circle tag-remove"></i>`;
                tag.querySelector('.tag-remove').addEventListener('click', () => {
                    tags.delete(text);
                    tag.remove();
                    updateHidden();
                });
                return tag;
            }

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault();
                    const value = input.value.trim();
                    if (value && !tags.has(value)) {
                        tags.add(value);
                        container.insertBefore(createTag(value), input);
                        input.value = '';
                        updateHidden();
                    }
                }
                if (e.key === 'Backspace' && !input.value && tags.size > 0) {
                    const lastTag = Array.from(tags).pop();
                    tags.delete(lastTag);
                    container.removeChild(container.children[container.children.length - 2]);
                    updateHidden();
                }
            });
        }

        setupTagsInput('domainTags', 'domainInput', 'job_domain');
        setupTagsInput('skillsTags', 'skillsInput', 'required_skills');

        // Form validation
        const form = document.getElementById('applicationForm');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', (e) => {
            let isValid = true;
            
            // Clear previous errors
            document.querySelectorAll('.error-message').forEach(el => el.textContent = '');
            document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));

            // Validate required fields
            const requiredFields = ['company_name', 'job_title', 'job_level', 'date_applied', 'app_method', 'job_description'];
            
            requiredFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (!field.value.trim()) {
                    isValid = false;
                    field.classList.add('error');
                    const errorDiv = document.getElementById(`error-${fieldId}`);
                    if (errorDiv) errorDiv.textContent = 'This field is required';
                }
            });

            // Validate URL fields
            const urlFields = ['company_website', 'job_posting_url', 'hiring_manager_linkedin'];
            urlFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && field.value) {
                    try {
                        new URL(field.value);
                    } catch {
                        if (fieldId === 'job_posting_url') {
                            isValid = false;
                            field.classList.add('error');
                        }
                    }
                }
            });

            if (!isValid) {
                e.preventDefault();
                // Scroll to first error
                const firstError = document.querySelector('.error');
                if (firstError) {
                    firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            } else {
                // Show loading state
                submitBtn.classList.add('btn-loading');
                submitBtn.disabled = true;
            }
        });

        // Auto-calculate follow-up date if not set
        const dateAppliedInput = document.getElementById('date_applied');
        const followUpInput = document.getElementById('follow_up_date');
        
        dateAppliedInput.addEventListener('change', () => {
            if (!followUpInput.value && dateAppliedInput.value) {
                const applied = new Date(dateAppliedInput.value);
                const followUp = new Date(applied);
                followUp.setDate(followUp.getDate() + 14); // 2 weeks later
                followUpInput.value = followUp.toISOString().split('T')[0];
            }
        });

        // Progress indicator update on scroll
        const sections = ['section-1', 'section-2', 'section-3'];
        const indicators = ['step1-indicator', 'step2-indicator', 'step3-indicator'];
        
        const observerOptions = {
            root: null,
            rootMargin: '-20% 0px -80% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const index = sections.indexOf(entry.target.id);
                    indicators.forEach((id, i) => {
                        const el = document.getElementById(id);
                        if (i < index) {
                            el.classList.add('completed');
                            el.classList.remove('active');
                            el.innerHTML = '<i class="bi bi-check-circle-fill"></i><span>' + el.querySelector('span').textContent + '</span>';
                        } else if (i === index) {
                            el.classList.add('active');
                            el.classList.remove('completed');
                        } else {
                            el.classList.remove('active', 'completed');
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach(id => {
            const el = document.getElementById(id);
            if (el) observer.observe(el);
        });

        // ========== ADD THIS NEW CODE HERE ==========
        // CV Analysis indicator
        const resumeFile = document.getElementById('resumeFile');
        const skillsInput = document.getElementById('skillsInput');
        const cvAnalysisInfo = document.getElementById('cvAnalysisInfo');

        function checkCvAnalysis() {
            const hasFile = resumeFile.files && resumeFile.files[0];
            const hasSkills = document.getElementById('required_skills').value.length > 0;
            if (cvAnalysisInfo) {
                cvAnalysisInfo.style.display = (hasFile && hasSkills) ? 'flex' : 'none';
            }
        }

        if (resumeFile) {
            resumeFile.addEventListener('change', checkCvAnalysis);
        }
        
        if (skillsInput) {
            skillsInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ',') {
                    setTimeout(checkCvAnalysis, 100);
                }
            });
            // Also check when removing tags (click on x)
            skillsInput.addEventListener('click', () => {
                setTimeout(checkCvAnalysis, 100);
            });
        }

        // Initial check
        checkCvAnalysis();
        // ========== END OF NEW CODE ==========

    </script>
</body>
</html>