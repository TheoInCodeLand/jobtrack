                                        <input type="radio" name="company_rating" value="10" id="star10"><label for="star10"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="9" id="star9"><label for="star9"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="8" id="star8"><label for="star8"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="7" id="star7"><label for="star7"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="6" id="star6"><label for="star6"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="5" id="star5" checked><label for="star5"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="4" id="star4"><label for="star4"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="3" id="star3"><label for="star3"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="2" id="star2"><label for="star2"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" name="company_rating" value="1" id="star1"><label for="star1"><i class="bi bi-star-fill"></i></label>
