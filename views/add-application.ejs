                                <div class="contact-card-title"><i class="bi bi-person-badge"></i> Hiring Contact (if known)</div>
                                <div class="form-row form-col-3">
                                    <div>
                                        <input type="text" name="hiring_manager_name" class="form-input" placeholder="Hiring Manager Name">
                                    </div>
                                    <div>
                                        <input type="email" name="hiring_manager_email" class="form-input" placeholder="HM Email">
                                    </div>
                                    <div>
                                        <input type="url" name="hiring_manager_linkedin" class="form-input" placeholder="HM LinkedIn URL">
                                    </div>
                                </div>
                                <div class="form-row form-col-2" style="margin-top: 0.75rem;">
                                    <div>
                                        <input type="text" name="recruiter_name" class="form-input" placeholder="Recruiter Name (if external)">
                                    </div>
                                    <div>
                                        <input type="text" name="recruiter_company" class="form-input" placeholder="Recruitment Agency">
                                    </div>
                                </div>
                            </div>

                            <div class="section-header"><i class="bi bi-calendar-event"></i> Application Timeline</div>
                            
                            <div class="form-row form-col-4">
                                <div>
                                    <label class="form-label required" for="date_applied">Date Applied</label>
                                    <input type="date" id="date_applied" name="date_applied" class="form-input" required 
                                           value="<%= new Date().toISOString().split('T')[0] %>">
                                </div>
                                <div>
                                    <label class="form-label" for="closing_date">Closing Date</label>
                                    <input type="date" id="closing_date" name="closing_date" class="form-input">
                                </div>
                                <div>
                                    <label class="form-label" for="follow_up_date">Follow-up Date</label>
                                    <input type="date" id="follow_up_date" name="follow_up_date" class="form-input">
                                </div>
                                <div>
                                    <label class="form-label" for="time_spent_minutes">Time Spent (mins)</label>
                                    <input type="number" id="time_spent_minutes" name="time_spent_minutes" class="form-input" 
                                           value="15" min="0" max="480">
                                </div>
                            </div>

                            <div class="form-row form-col-3">
                                <div>
                                    <label class="form-label required" for="app_method">Application Method</label>
                                    <select id="app_method" name="app_method" class="form-select" required onchange="toggleOtherMethod()">
                                        <option value="">Select method...</option>
                                        <option value="LinkedIn Easy Apply">LinkedIn Easy Apply</option>
                                        <option value="LinkedIn Manual">LinkedIn (Manual)</option>
                                        <option value="Indeed">Indeed</option>
                                        <option value="Company Website">Company Careers Portal</option>
                                        <option value="Email">Direct Email</option>
                                        <option value="Referral">Employee Referral</option>
                                        <option value="Recruiter">External Recruiter</option>
