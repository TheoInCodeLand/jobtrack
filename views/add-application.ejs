                        <div class="card-header">
                            <h2 class="card-title"><i class="bi bi-clipboard-data"></i> Application Strategy</h2>
                        </div>
                        <div class="card-content">
                            
                            <!-- Referral Section -->
                            <div class="form-check" style="margin-bottom: 0.75rem;">
                                <input class="form-check-input" type="checkbox" name="referral" value="true" id="referralCheck" onchange="toggleReferralDetails()">
                                <label class="form-check-label" for="referralCheck">
                                    <strong>This is an employee referral</strong> 
                                    <span class="text-muted">(higher response rates!)</span>
                                </label>
                            </div>
                            
                            <div id="referralDetails" class="conditional-section">
                                <div class="form-row form-col-2">
                                    <div>
                                        <label class="form-label">Referrer Name</label>
