                                <div style="display: flex; flex-direction: column; gap: 0.5rem; justify-content: flex-end;">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="salary_transparent" value="true" id="salaryTransparent">
                                        <label class="form-check-label" for="salaryTransparent">Salary Listed?</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="assessment_upfront" value="true" id="assessmentCheck" onchange="toggleAssessmentType()">
                                        <label class="form-check-label" for="assessmentCheck">Assessment Required?</label>
                                    </div>
                                </div>
                            </div>

                            <div id="assessmentTypeContainer" class="conditional-section">
                                <label class="form-label">Assessment Type</label>
                                <select name="assessment_type" class="form-select">
                                    <option value="">Select type...</option>
                                    <option value="Coding Challenge">Coding Challenge</option>
                                    <option value="Psychometric">Psychometric Test</option>
                                    <option value="Video Interview">Video Interview (One-way)</option>
                                    <option value="Case Study">Case Study</option>
                                    <option value="Technical Test">Technical Test</option>
                                    <option value="Portfolio Review">Portfolio Review</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>

                            <div class="section-header"><i class="bi bi-tags"></i> Skills & Categorization</div>
                            
                            <div class="form-row form-col-2">
