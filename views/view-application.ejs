                    <li class="sidebar-menu-item">
                        <a href="/smart-ats" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                            <span>Smart ATS</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/profile" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Profile</span>
                        </a>
                    </li>
                    <li>
                        <a href="/user/settings" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar" style="background: linear-gradient(135deg, hsl(var(--primary)), hsl(221.2 83.2% 46%));">
                        <%= user ? user.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name"><%= user || 'User' %></span>
                        <span class="sidebar-user-role">Job Seeker</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="topbar-search">
                    <button class="mobile-toggle" id="mobileToggle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                    </button>
                    <div class="search-input-wrapper">
                        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                        <input type="text" class="search-input" placeholder="Search applications...">
                    </div>
                </div>
                <div class="topbar-actions">
                    <a href="/ats/check/<%= app.id %>" class="btn btn-outline btn-sm">
                        <i class="bi bi-robot"></i> Run AI ATS Check
                    </a>
                    <a href="/applications/edit/<%= app.id %>" class="btn btn-outline btn-sm">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a href="/applications/add" class="btn btn-outline btn-sm">
                        <i class="bi bi-plus-circle"></i> New Application
                    </a>
                    <div class="dropdown">
                        <button class="avatar-button" id="userBtn">
                            <div class="avatar-placeholder">
                                <%= user ? user.charAt(0).toUpperCase() : 'U' %>
                            </div>
                        </button>
                        <div class="dropdown-content" id="userDropdown">
                            <div class="dropdown-label">My Account</div>
                            <div class="dropdown-separator"></div>
                            <a href="/auth/logout" class="dropdown-item" style="color: hsl(var(--destructive));">Log out</a>
                        </div>
                    </div>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <div class="page-content">
                <!-- Header with job title and status -->
                <div class="page-header">
                    <div>
                        <h1 class="page-title"><%= app.job_title %></h1>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <span class="badge <%= 
                                app.status === 'applied' ? 'badge-applied' :
                                app.status.includes('interview') ? 'badge-interview' :
                                app.status === 'offer received' ? 'badge-offer' :
                                app.status === 'rejected' ? 'badge-rejected' :
                                app.status === 'ghosted' ? 'badge-ghosted' :
                                app.status === 'shortlisted' ? 'badge-shortlisted' : 'badge-applied'
                            %>"><%= app.status.toUpperCase() %></span>
                            <h5 class="mb-0 fw-normal"><i class="bi bi-building me-1 text-muted"></i> <%= app.company_name %></h5>
                        </div>
                    </div>
                    <div class="d-flex gap-4 align-items-center">
                        <div class="text-end">
                            <div class="detail-label">Salary Range</div>
                            <div class="fs-5 fw-bold text-success"><%= app.salary || 'Not Disclosed' %></div>
                        </div>
                        <div class="text-end">
                            <div class="detail-label">Location</div>
                            <div class="fs-6 fw-bold"><%= app.location || 'Remote' %> <span class="badge badge-secondary"><%= app.work_arrangement %></span></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Left column: Quick actions, contact info, metrics -->
                    <div class="col-lg-4">
                        <!-- Quick Actions Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6><i class="bi bi-lightning-charge-fill me-2"></i>Quick Actions</h6>
                            </div>
                            <div class="card-content">
                                <div class="d-flex flex-column gap-2">
                                    <button class="btn btn-outline justify-content-between" onclick="openModal('interviewModal')">
                                        <span><i class="bi bi-calendar-check text-primary me-2"></i> Log Interview</span>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                    <button class="btn btn-outline justify-content-between" onclick="openModal('commModal')">
                                        <span><i class="bi bi-chat-dots text-success me-2"></i> Log Communication</span>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                    <button class="btn btn-outline justify-content-between" onclick="openModal('statusModal')">
                                        <span><i class="bi bi-arrow-repeat text-secondary me-2"></i> Change Status</span>
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                                <% if (app.resume_path) { %>
                                <hr class="my-3 border">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-muted">Version: <strong><%= app.resume_version_used || 'Default' %></strong></span>
                                    <a href="<%= app.resume_path %>" target="_blank" class="btn btn-outline btn-sm">
                                        <i class="bi bi-file-pdf"></i> View CV
                                    </a>
                                </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Offer Card (if applicable) -->
                        <% if (app.status === 'offer received' || app.offer_amount) { %>
                        <div class="card mb-4 border-success">
                            <div class="card-header bg-success bg-opacity-10">
                                <h6 class="text-success"><i class="bi bi-cash-coin me-2"></i>Offer Details</h6>
                            </div>
                            <div class="card-content">
                                <div class="detail-label">Offered Amount</div>
                                <div class="detail-value fs-5 text-success"><%= app.offer_amount || 'Pending Details' %></div>
                                <div class="detail-label mt-2">Time to Offer</div>
                                <div class="detail-value"><%= app.time_to_offer_days ? app.time_to_offer_days + ' Days' : 'Calculating...' %></div>
                            </div>
                        </div>
                        <% } %>

                        <!-- Application Info Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6><i class="bi bi-info-circle me-2"></i>Application Info</h6>
                            </div>
                            <div class="card-content">
                                <div class="row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                                    <div>
                                        <div class="detail-label">Date Applied</div>
                                        <div class="detail-value"><%= new Date(app.date_applied).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                                    </div>
                                    <div>
                                        <div class="detail-label">App Method</div>
                                        <div class="detail-value"><%= app.app_method || 'Direct' %></div>
                                    </div>
                                    <div>
                                        <div class="detail-label">Company Size</div>
                                        <div class="detail-value"><%= app.company_size || 'Unknown' %></div>
                                    </div>
                                    <div>
                                        <div class="detail-label">Industry</div>
                                        <div class="detail-value"><%= app.industry || 'Not Specified' %></div>
                                    </div>
                                </div>
                                <% if (app.company_website || app.job_posting_url) { %>
                                <hr class="my-2 border">
                                <div class="d-flex gap-2 mt-2">
                                    <% if (app.company_website) { %>
                                        <a href="<%= app.company_website %>" target="_blank" class="badge badge-primary text-decoration-none"><i class="bi bi-globe"></i> Website</a>
                                    <% } %>
                                    <% if (app.job_posting_url) { %>
                                        <a href="<%= app.job_posting_url %>" target="_blank" class="badge badge-primary text-decoration-none"><i class="bi bi-link-45deg"></i> Job Post</a>
                                    <% } %>
                                </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Networking Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6><i class="bi bi-people me-2"></i>Networking</h6>
                            </div>
                            <div class="card-content">
                                <div class="detail-label">Referral Source</div>
                                <div class="detail-value">
                                    <% if (app.referral && app.referrer_name) { %>
                                        <span class="badge badge-success"><i class="bi bi-person-check-fill me-1"></i> <%= app.referrer_name %></span>
                                        <div class="small text-muted mt-1"><%= app.referrer_relationship || 'Connection' %></div>
                                    <% } else { %>
                                        <span class="text-muted">No referral used.</span>
                                    <% } %>
                                </div>

                                <% if (app.hiring_manager_name) { %>
                                    <div class="detail-label mt-3">Hiring Manager</div>
                                    <div class="detail-value mb-1"><%= app.hiring_manager_name %></div>
                                    <% if (app.hiring_manager_linkedin) { %>
                                        <a href="<%= app.hiring_manager_linkedin %>" target="_blank" class="small text-decoration-none"><i class="bi bi-linkedin"></i> LinkedIn Profile</a>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>

                        <!-- Metrics Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6><i class="bi bi-bar-chart me-2"></i>Metrics</h6>
                            </div>
                            <div class="card-content p-0">
                                <ul style="list-style: none; margin: 0;">
                                    <li class="d-flex justify-content-between align-items-center p-3 border-bottom">
                                        <span class="small text-muted">Response Time</span>
                                        <span class="fw-bold"><%= app.response_time_days ? app.response_time_days + ' days' : 'Pending' %></span>
                                    </li>
                                    <li class="d-flex justify-content-between align-items-center p-3 border-bottom">
                                        <span class="small text-muted">Time Invested</span>
                                        <span class="fw-bold"><%= app.time_spent_minutes %> mins</span>
                                    </li>
                                    <li class="d-flex justify-content-between align-items-center p-3">
                                        <span class="small text-muted">Tailored Resume</span>
                                        <span>
                                            <% if(app.tailored_resume) { %><i class="bi bi-check-circle-fill text-success"></i><% } else { %><i class="bi bi-x-circle-fill text-danger"></i><% } %>
                                        </span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Right column: Skills, Timeline, Job Description -->
                    <div class="col-lg-8">
                        <!-- Skills Analysis Card -->
                        <div class="card mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h6><i class="bi bi-radar me-2"></i>Skills Analysis</h6>
                                <span class="badge badge-primary">Experience Required: <%= app.experience_level || '0' %> yrs</span>
                            </div>
                            <div class="card-content">
                                <div class="row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                                    <div>
                                        <div class="detail-label text-success mb-2"><i class="bi bi-check-circle me-1"></i> Skills You Have (<%= app.skills_you_have ? app.skills_you_have.length : 0 %>)</div>
                                        <div>
                                            <% if (app.skills_you_have && app.skills_you_have.length > 0) { %>
                                                <% app.skills_you_have.forEach(skill => { %>
                                                    <span class="skill-pill skill-match"><%= skill %></span>
                                                <% }) %>
                                            <% } else { %>
                                                <p class="text-muted small">No matching skills identified.</p>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="detail-label text-danger mb-2"><i class="bi bi-exclamation-circle me-1"></i> Skills To Review (<%= app.skills_you_lack ? app.skills_you_lack.length : 0 %>)</div>
                                        <div>
                                            <% if (app.skills_you_lack && app.skills_you_lack.length > 0) { %>
                                                <% app.skills_you_lack.forEach(skill => { %>
                                                    <span class="skill-pill skill-gap"><%= skill %></span>
                                                <% }) %>
                                            <% } else { %>
                                                <p class="text-muted small">You meet all listed requirements!</p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Card -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h6><i class="bi bi-signpost-split me-2"></i>Application Timeline</h6>
                            </div>
                            <div class="card-content">
                                <% if ((app.interview_rounds && app.interview_rounds.length > 0) || (app.logs && app.logs.length > 0)) { %>
                                    <div class="timeline">
                                        <% if (app.interview_rounds) { app.interview_rounds.forEach(round => { %>
                                            <div class="timeline-item">
                                                <div class="timeline-icon" style="background-color: hsl(var(--primary));">
                                                    <i class="bi bi-camera-video"></i>
                                                </div>
                                                <div class="timeline-content">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <h6 class="fw-bold mb-0">Round <%= round.round_name %><% if (round.format) { %>: <%= round.format %><% } %></h6>
                                                        <span class="badge badge-secondary"><%= new Date(round.date).toLocaleDateString() %></span>
                                                    </div>
                                                    <div class="small text-muted mb-2"><strong>Interviewers:</strong> <%= round.interviewers || 'Not specified' %></div>
                                                    <% if (round.notes) { %>
                                                        <div class="bg-light p-2 rounded small"><%= round.notes %></div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% })} %>

                                        <% if (app.logs) { app.logs.forEach(log => { %>
                                            <div class="timeline-item">
                                                <div class="timeline-icon" style="background-color: hsl(var(--status-offer-bg));">
                                                    <i class="bi bi-envelope"></i>
                                                </div>
                                                <div class="timeline-content">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <h6 class="fw-bold mb-0"><%= log.action %></h6>
                                                        <span class="badge badge-secondary"><%= new Date(log.date).toLocaleDateString() %></span>
                                                    </div>
                                                    <p class="small text-muted mb-0"><%= log.details %></p>
                                                </div>
                                            </div>
                                        <% })} %>

                                        <div class="timeline-item">
                                            <div class="timeline-icon" style="background-color: hsl(var(--muted-foreground));">
                                                <i class="bi bi-send"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <h6 class="fw-bold mb-0">Application Submitted</h6>
                                                    <span class="badge badge-secondary"><%= new Date(app.date_applied).toLocaleDateString() %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } else { %>
                                    <div class="text-center py-4">
                                        <i class="bi bi-inbox text-muted fs-1"></i>
                                        <p class="text-muted mt-2 mb-0">No timeline events recorded yet. Log an interview or communication to start tracking.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Job Description Accordion -->
                        <div class="card">
                            <div class="card-header" style="cursor: pointer;" onclick="toggleJD()">
                                <h6 class="d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-file-text me-2"></i> Original Job Description</span>
                                    <i class="bi bi-chevron-down" id="jdChevron"></i>
                                </h6>
                            </div>
                            <div id="jdContent" class="card-content" style="display: none; max-height: 500px; overflow-y: auto;">
                                <div style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6;">
                                    <%= app.job_description || 'No job description saved for this application.' %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Custom Modals (Status, Communication, Interview) -->
    <div class="modal-overlay" id="statusModal" onclick="closeModalOnBackdrop(event, 'statusModal')">
        <div class="modal-card">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6>Update Application Status</h6>
                    <button class="btn btn-ghost btn-sm" onclick="closeModal('statusModal')"><i class="bi bi-x-lg"></i></button>
                </div>
                <form action="/applications/update-status/<%= app.id %>" method="POST">
                    <div class="card-content">
                        <div class="mb-3">
                            <label class="form-label text-muted small">Current Status: <%= app.status %></label>
                            <select name="status" class="form-select" id="statusSelect" onchange="toggleRejectionSection()">
                                <option value="applied" <%= app.status === 'applied' ? 'selected' : '' %>>Applied</option>
                                <option value="shortlisted" <%= app.status === 'shortlisted' ? 'selected' : '' %>>Shortlisted</option>
                                <option value="phone screen" <%= app.status === 'phone screen' ? 'selected' : '' %>>Phone Screen</option>
                                <option value="interview" <%= app.status === 'interview' ? 'selected' : '' %>>Interviewing</option>
                                <option value="offer received" <%= app.status === 'offer received' ? 'selected' : '' %>>Offer Received</option>
                                <option value="rejected" <%= app.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                <option value="withdrawn" <%= app.status === 'withdrawn' ? 'selected' : '' %>>Withdrawn</option>
                                <option value="ghosted" <%= app.status === 'ghosted' ? 'selected' : '' %>>Ghosted</option>
                            </select>
                        </div>

                        <div id="rejectionSection" class="<%= app.status === 'rejected' ? '' : 'd-none' %> bg-danger bg-opacity-10 p-3 rounded">
                            <label class="form-label text-danger fw-bold mb-1">Rejection Stage</label>
                            <input type="text" name="rejection_stage" class="form-input mb-2" placeholder="e.g., After Tech Assessment" value="<%= app.rejection_stage || '' %>">
                            <label class="form-label text-danger fw-bold mb-1">Reason / Feedback</label>
                            <textarea name="rejection_reason" class="form-input" rows="3" placeholder="What feedback did they provide?"><%= app.rejection_reason || '' %></textarea>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-end gap-2 border-0 pt-0">
                        <button type="button" class="btn btn-outline" onclick="closeModal('statusModal')">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Status</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="commModal" onclick="closeModalOnBackdrop(event, 'commModal')">
        <div class="modal-card">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6>Log Communication</h6>
                    <button class="btn btn-ghost btn-sm" onclick="closeModal('commModal')"><i class="bi bi-x-lg"></i></button>
                </div>
                <form action="/applications/log-comm/<%= app.id %>" method="POST">
                    <div class="card-content">
                        <div class="mb-3">
                            <label class="form-label">Action / Type</label>
                            <input type="text" name="action" class="form-input" placeholder="e.g., Sent Follow-up Email, Received Assessment Link" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Details</label>
                            <textarea name="details" class="form-input" rows="4" placeholder="Paste the email content or write brief notes here..." required></textarea>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-end gap-2 border-0 pt-0">
                        <button type="button" class="btn btn-outline" onclick="closeModal('commModal')">Cancel</button>
                        <button type="submit" class="btn btn-success">Save to Timeline</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="interviewModal" onclick="closeModalOnBackdrop(event, 'interviewModal')">
        <div class="modal-card">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6>Schedule / Log Interview</h6>
                    <button class="btn btn-ghost btn-sm" onclick="closeModal('interviewModal')"><i class="bi bi-x-lg"></i></button>
                </div>
                <form action="/applications/add-interview/<%= app.id %>" method="POST">
                    <div class="card-content">
                        <div class="d-flex gap-2 mb-3">
                            <div style="flex: 1;">
                                <label class="form-label">Round Description</label>
                                <input type="text" name="round_name" class="form-input" placeholder="e.g., Technical Panel" required>
                            </div>
                            <div style="flex: 1;">
                                <label class="form-label">Date</label>
                                <input type="date" name="date" class="form-input" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Format</label>
                            <select name="format" class="form-select">
                                <option value="Video Call">Video Call</option>
                                <option value="Phone Screen">Phone Screen</option>
                                <option value="On-site">On-site</option>
                                <option value="Take-home Assessment">Take-home Assessment</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Interviewer(s) Name & Titles</label>
                            <input type="text" name="interviewers" class="form-input" placeholder="e.g., John Doe (Senior Dev)">
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-end gap-2 border-0 pt-0">
                        <button type="button" class="btn btn-outline" onclick="closeModal('interviewModal')">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add to Timeline</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Mobile sidebar toggle
        const mobileToggle = document.getElementById('mobileToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');

        if (mobileToggle) {
            mobileToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('show');
            });
        }
        if (overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            });
        }

        // User dropdown
        const userBtn = document.getElementById('userBtn');
        const userDropdown = document.getElementById('userDropdown');
        if (userBtn && userDropdown) {
            userBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                userDropdown.classList.toggle('show');
            });
            document.addEventListener('click', () => {
                userDropdown.classList.remove('show');
            });
        }

        // Modal functions
        function openModal(id) {
            document.getElementById(id).classList.add('show');
        }
        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }
        function closeModalOnBackdrop(event, id) {
            if (event.target.classList.contains('modal-overlay')) {
                closeModal(id);
            }
        }

        // Toggle rejection section in status modal
        function toggleRejectionSection() {
            const status = document.getElementById('statusSelect').value;
            const rejectionSection = document.getElementById('rejectionSection');
            if (status === 'rejected') {
                rejectionSection.classList.remove('d-none');
            } else {
                rejectionSection.classList.add('d-none');
            }
        }

        // Toggle job description accordion
        function toggleJD() {
            const jdContent = document.getElementById('jdContent');
            const chevron = document.getElementById('jdChevron');
            if (jdContent.style.display === 'none') {
                jdContent.style.display = 'block';
                chevron.classList.remove('bi-chevron-down');
                chevron.classList.add('bi-chevron-up');
            } else {
                jdContent.style.display = 'none';
                chevron.classList.remove('bi-chevron-up');
                chevron.classList.add('bi-chevron-down');
            }
        }
    </script>
</body>
</html>