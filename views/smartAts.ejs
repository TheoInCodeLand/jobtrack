                    <li>
                        <a href="/user/settings" class="sidebar-menu-button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar"><%= user.charAt(0).toUpperCase() %></div>
                    <div>
                        <div class="sidebar-user-name"><%= user %></div>
                        <div class="sidebar-user-role">Job Seeker</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <h1 class="page-title">Smart ATS Analyzer</h1>
                <div class="topbar-actions">
                    <a href="/applications/dashboard" class="btn btn-outline">Back to Dashboard</a>
                </div>
            </header>

            <!-- Page Content -->
            <div class="page-content">
                <!-- Input Form -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Analyze Your Application</h2>
                        <p class="card-description">Get AI-powered feedback from a senior recruiter's perspective</p>
                    </div>
                    <div class="card-content">
                        <% if (error) { %>
                            <div class="error-message"><%= error %></div>
                        <% } %>

                        <form id="smartAtsForm">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Select Application</label>
                                    <select name="applicationId" id="applicationId" class="form-select" required>
                                        <option value="">Choose a job application...</option>
                                        <% applications.forEach(app => { %>
                                            <option value="<%= app.id %>">
                                                <%= app.company_name %> - <%= app.job_title %>
                                                <%= app.resume_path ? '' : ' (No resume)' %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Job Level</label>
                                    <select name="jobLevel" id="jobLevel" class="form-select">
                                        <option value="entry">Entry Level (0-2 years)</option>
                                        <option value="mid" selected>Mid Level (3-5 years)</option>
                                        <option value="senior">Senior Level (5-8 years)</option>
                                        <option value="lead">Lead/Principal (8+ years)</option>
                                        <option value="executive">Executive/C-Level</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Job Type/Industry</label>
                                <select name="jobType" id="jobType" class="form-select">
                                    <option value="software_engineering">Software Engineering / Development</option>
                                    <option value="data_science">Data Science / Machine Learning</option>
                                    <option value="product_management">Product Management</option>
                                    <option value="project_management">Project Management</option>
                                    <option value="devops">DevOps / SRE / Platform Engineering</option>
                                    <option value="design">UX/UI Design</option>
                                    <option value="marketing">Marketing / Growth</option>
                                    <option value="sales">Sales / Business Development</option>
                                    <option value="hr">Human Resources / Talent</option>
                                    <option value="finance">Finance / Accounting</option>
                                    <option value="operations">Operations</option>
                                    <option value="consulting">Consulting</option>
                                    <option value="other">Other / General</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Job Description</label>
                                <textarea name="jobDescription" id="jobDescription" class="form-textarea" 
                                    placeholder="Paste the full job description here. The more detail you provide, the better the analysis will be..." required></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary" id="analyzeBtn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                Analyze My Chances
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Results Section -->
                <div id="resultsSection" class="results-section">
                    <!-- Overall Score -->
                    <div class="score-display">
                        <div class="score-circle">
                            <div class="score-value" id="overallScore">0</div>
                            <div class="score-label">out of 100</div>
                        </div>
                        <div class="score-details">
                            <div class="verdict-title" id="verdictTitle">Analyzing...</div>
                            <div class="verdict-summary" id="verdictSummary"></div>
                            <div class="chance-badge" id="chanceBadge">Chance: Calculating...</div>
                        </div>
                    </div>

                    <!-- Score Breakdown -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Score Breakdown</h3>
                        </div>
                        <div class="card-content">
                            <div class="score-breakdown" id="scoreBreakdown">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Strengths & Gaps -->
                    <div class="section-grid">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Your Strengths</h3>
                            </div>
                            <div class="card-content">
                                <ul class="item-list" id="strengthsList">
                                    <!-- Populated by JS -->
                                </ul>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Critical Gaps</h3>
                            </div>
                            <div class="card-content">
                                <ul class="item-list" id="gapsList">
                                    <!-- Populated by JS -->
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Section Recommendations -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Section-by-Section Recommendations</h3>
                        </div>
                        <div class="card-content">
                            <div class="section-grid" id="sectionRecommendations">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- ATS Optimization -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">ATS Optimization</h3>
                        </div>
                        <div class="card-content">
                            <div class="section-grid">
                                <div>
                                    <h4 class="section-card-title">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                                        Keywords to Add
                                    </h4>
                                    <div class="tag-list" id="keywordsToAdd">
                                        <!-- Populated by JS -->
                                    </div>
                                </div>
                                <div>
                                    <h4 class="section-card-title">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5 9-9"/></svg>
                                        Keywords to Emphasize
                                    </h4>
                                    <div class="tag-list" id="keywordsToEmphasize">
                                        <!-- Populated by JS -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Priority Actions -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Priority Actions</h3>
                        </div>
                        <div class="card-content">
                            <div class="priority-actions" id="priorityActions">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Tailored Advice -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Tailored Advice</h3>
                        </div>
                        <div class="card-content">
                            <div class="section-grid" id="tailoredAdvice">
                                <!-- Populated by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Recruiter Insights -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Recruiter Insights</h3>
                        </div>
                        <div class="card-content">
                            <div class="insight-box">
                                <div class="insight-title">First 6-Second Impression</div>
                                <div class="insight-text" id="firstImpression"></div>
                                
                                <div class="flag-list" id="flagsList">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.getElementById('smartAtsForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = {
                applicationId: document.getElementById('applicationId').value,
                jobLevel: document.getElementById('jobLevel').value,
                jobType: document.getElementById('jobType').value,
                jobDescription: document.getElementById('jobDescription').value
            };
            
            if (!formData.applicationId) {
                alert('Please select an application');
                return;
            }
            
            // Show loading
            document.getElementById('loadingOverlay').classList.add('show');
            document.getElementById('analyzeBtn').disabled = true;
            
            try {
                const response = await fetch('/smart-ats/analyze', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                
                if (!response.ok) {
                    throw new Error(data.error || 'Analysis failed');
                }
                
                if (!data.analysis) {
                    throw new Error('No analysis data received from server');
                }
                
                displayResults(data.analysis);
                
            } catch (error) {
                alert('Error: ' + error.message);
                console.error('Analysis error:', error);
            } finally {
                document.getElementById('loadingOverlay').classList.remove('show');
                document.getElementById('analyzeBtn').disabled = false;
            }
        });
        
        function displayResults(analysis) {
            // Validate analysis object
            if (!analysis || typeof analysis !== 'object') {
                console.error('Invalid analysis data:', analysis);
                alert('Invalid analysis data received');
                return;
            }
            
            const resultsSection = document.getElementById('resultsSection');
            resultsSection.classList.add('show', 'animate-in');
            
            // Scroll to results
            resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            // Overall Score - ensure it's a number
            const score = Number(analysis.overallScore) || 0;
            const scoreEl = document.getElementById('overallScore');
            scoreEl.textContent = score;
            scoreEl.className = 'score-value ' + getScoreClass(score);
            
            // Verdict - ensure object exists
            const verdict = analysis.verdict || {};
            const verdictTitle = document.getElementById('verdictTitle');
            verdictTitle.textContent = verdict.rating || 'Analysis Complete';
            verdictTitle.className = 'verdict-title ' + getVerdictClass(verdict.rating);
            
            document.getElementById('verdictSummary').textContent = verdict.summary || 'No summary available.';
            
            const chanceBadge = document.getElementById('chanceBadge');
            const chanceText = verdict.chanceOfGettingJob || 'Unknown';
            chanceBadge.textContent = 'Chance of Getting Job: ' + chanceText;
            chanceBadge.className = 'chance-badge ' + getChanceClass(chanceText);
            
            // Score Breakdown - handle missing fields
            const breakdown = analysis.scoreBreakdown || {};
            const breakdownEl = document.getElementById('scoreBreakdown');
            breakdownEl.innerHTML = `
                <div class="breakdown-item">
                    <div class="breakdown-score">${breakdown.keywordMatch || 0}</div>
                    <div class="breakdown-label">Keyword Match</div>
                </div>
                <div class="breakdown-item">
                    <div class="breakdown-score">${breakdown.experienceAlignment || 0}</div>
                    <div class="breakdown-label">Experience</div>
                </div>
                <div class="breakdown-item">
                    <div class="breakdown-score">${breakdown.skillsRelevance || 0}</div>
                    <div class="breakdown-label">Skills</div>
                </div>
                <div class="breakdown-item">
                    <div class="breakdown-score">${breakdown.formattingATS || 0}</div>
                    <div class="breakdown-label">ATS Format</div>
                </div>
                <div class="breakdown-item">
                    <div class="breakdown-score">${breakdown.achievementsImpact || 0}</div>
                    <div class="breakdown-label">Impact</div>
                </div>
            `;
            
            // Strengths - handle missing arrays
            const strengthsList = document.getElementById('strengthsList');
            const strengths = analysis.strengths || [];
            if (strengths.length > 0) {
                strengthsList.innerHTML = strengths.map(s => `
                    <li>
                        <div class="item-title">${escapeHtml(s.area || 'Strength')}</div>
                        <div class="item-desc">${escapeHtml(s.description || '')}</div>
                        <div class="item-action">${escapeHtml(s.impact || '')}</div>
                    </li>
                `).join('');
            } else {
                strengthsList.innerHTML = '<li style="border-left-color: hsl(var(--muted-foreground));"><div class="item-desc">No specific strengths identified</div></li>';
            }
            
            // Gaps - handle missing arrays
            const gapsList = document.getElementById('gapsList');
            const gaps = analysis.criticalGaps || [];
            if (gaps.length > 0) {
                gapsList.innerHTML = gaps.map(g => `
                    <li class="${(g.severity || 'medium').toLowerCase()}">
                        <div class="item-title">${escapeHtml(g.area || 'Area for Improvement')}</div>
                        <div class="item-desc">${escapeHtml(g.description || '')}</div>
                        <div class="item-action">Fix: ${escapeHtml(g.howToFix || 'Review this area')}</div>
                    </li>
                `).join('');
            } else {
                gapsList.innerHTML = '<li style="border-left-color: hsl(var(--score-excellent));"><div class="item-desc">No critical gaps identified - great job!</div></li>';
            }
            
            // Section Recommendations
            const sectionRecs = analysis.sectionBySectionRecommendations || {};
            const sectionEl = document.getElementById('sectionRecommendations');
            const sections = Object.entries(sectionRecs);
            if (sections.length > 0) {
                sectionEl.innerHTML = sections.map(([section, advice]) => `
                    <div class="section-card">
                        <div class="section-card-title">${escapeHtml(section.charAt(0).toUpperCase() + section.slice(1))}</div>
                        <div class="section-card-content">${escapeHtml(advice || 'No specific advice')}</div>
                    </div>
                `).join('');
            } else {
                sectionEl.innerHTML = '<div class="section-card"><div class="section-card-content">No section-specific recommendations available</div></div>';
            }
            
            // ATS Optimization
            const atsOpt = analysis.atsOptimization || {};
            const keywordsToAdd = atsOpt.keywordsToAdd || [];
            const keywordsToEmphasize = atsOpt.keywordsToEmphasize || [];
            
            document.getElementById('keywordsToAdd').innerHTML = keywordsToAdd.length > 0 
                ? keywordsToAdd.map(k => `<span class="tag warning">${escapeHtml(k)}</span>`).join('') 
                : '<span class="tag" style="background-color: hsl(var(--muted)); color: hsl(var(--muted-foreground));">No keywords suggested</span>';
                
            document.getElementById('keywordsToEmphasize').innerHTML = keywordsToEmphasize.length > 0 
                ? keywordsToEmphasize.map(k => `<span class="tag success">${escapeHtml(k)}</span>`).join('') 
                : '<span class="tag" style="background-color: hsl(var(--muted)); color: hsl(var(--muted-foreground));">No keywords to emphasize</span>';
            
            // Priority Actions
            const priorityEl = document.getElementById('priorityActions');
            const actions = analysis.priorityActions || [];
            if (actions.length > 0) {
                priorityEl.innerHTML = actions.map((action, idx) => `
                    <div class="priority-item">
                        <div class="priority-number">${action.priority || idx + 1}</div>
                        <div class="priority-content">
                            <div class="priority-action">${escapeHtml(action.action || 'Action item')}</div>
                            <div class="priority-impact">${escapeHtml(action.expectedImpact || '')}</div>
                        </div>
                    </div>
                `).join('');
            } else {
                priorityEl.innerHTML = '<div class="priority-item"><div class="priority-content"><div class="priority-action">No priority actions identified</div></div></div>';
            }
            
            // Tailored Advice
            const tailored = analysis.tailoredAdvice || {};
            document.getElementById('tailoredAdvice').innerHTML = `
                <div class="section-card">
                    <div class="section-card-title">For This Job Level</div>
                    <div class="section-card-content">${escapeHtml(tailored.forThisJobLevel || 'No specific advice for this level')}</div>
                </div>
                <div class="section-card">
                    <div class="section-card-title">For This Industry</div>
                    <div class="section-card-content">${escapeHtml(tailored.forThisIndustry || 'No specific industry advice')}</div>
                </div>
                <div class="section-card">
                    <div class="section-card-title">Competitive Positioning</div>
                    <div class="section-card-content">${escapeHtml(tailored.competitivePositioning || 'No positioning advice')}</div>
                </div>
            `;
            
            // Recruiter Insights
            const insights = analysis.recruiterInsights || {};
            document.getElementById('firstImpression').textContent = insights.firstImpression || 'No first impression data available';
            
            const flagsList = document.getElementById('flagsList');
            let flagsHtml = '';
            
            if (insights.redFlags && insights.redFlags.length > 0) {
                flagsHtml += insights.redFlags.map(f => `
                    <div class="flag-item red">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg>
                        ${escapeHtml(f)}
                    </div>
                `).join('');
            }
            
            if (insights.greenFlags && insights.greenFlags.length > 0) {
                flagsHtml += insights.greenFlags.map(f => `
                    <div class="flag-item green">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        ${escapeHtml(f)}
                    </div>
                `).join('');
            }
            
            if (!flagsHtml) {
                flagsHtml = '<div class="flag-item" style="color: hsl(var(--muted-foreground));">No specific flags identified</div>';
            }
            
            flagsList.innerHTML = flagsHtml;
        }
        
        // Helper function to prevent XSS
        function escapeHtml(text) {
            if (typeof text !== 'string') return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        function getScoreClass(score) {
            if (score >= 80) return 'excellent';
            if (score >= 65) return 'good';
            if (score >= 50) return 'average';
            return 'poor';
        }
        
        function getVerdictClass(rating) {
            if (!rating) return '';
            const lower = rating.toLowerCase();
            if (lower.includes('strong')) return 'strong';
            if (lower.includes('competitive')) return 'competitive';
            if (lower.includes('marginal')) return 'marginal';
            return 'weak';
        }
        
        function getChanceClass(chance) {
            if (!chance) return '';
            const lower = chance.toLowerCase();
            if (lower.includes('high')) return 'high';
            if (lower.includes('medium')) return 'medium';
            if (lower.includes('very low')) return 'very-low';
            return 'low';
        }
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Check if there is auto-run data waiting for us
        const autoRunParam = sessionStorage.getItem('atsAutoRun');
        
        if (autoRunParam) {
            try {
                const data = JSON.parse(autoRunParam);
                
                // 1. Select the Application
                const appSelect = document.getElementById('applicationId');
                if (appSelect && data.id) appSelect.value = data.id;

                // 2. Fill the Job Description
                const descInput = document.getElementById('jobDescription');
                if (descInput && data.desc) descInput.value = data.desc;

                // 3. Smart-match the Job Level
                if (data.level) {
                    const levelSelect = document.getElementById('jobLevel');
                    const levelText = data.level.toLowerCase();
                    // Try to find a matching option (e.g. matching "Senior" to "Senior Level")
                    for (let option of levelSelect.options) {
                        if (option.text.toLowerCase().includes(levelText) || option.value.toLowerCase().includes(levelText)) {
                            levelSelect.value = option.value;
                            break;
                        }
                    }
                }

                // 4. Smart-match the Industry/Job Type
                if (data.industry) {
                    const typeSelect = document.getElementById('jobType');
                    const indText = data.industry.toLowerCase();
                    for (let option of typeSelect.options) {
                        if (option.text.toLowerCase().includes(indText) || option.value.toLowerCase().includes(indText)) {
                            typeSelect.value = option.value;
                            break;
                        }
                    }
                }

                // Clean up storage so it doesn't loop if the user refreshes the page manually
                sessionStorage.removeItem('atsAutoRun');

                // Auto-submit the form if we have the minimum required fields
                if (appSelect.value && descInput.value) {
                    // Dispatching a submit event triggers your existing fetch logic
                    document.getElementById('smartAtsForm').dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
                }

            } catch (err) {
                console.error('Error auto-running ATS:', err);
            }
        }
    });
</script>
</body>
</html>
