<!-- views/ats-analyzer.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ATS Resume Analyzer | Optimus AI</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: #333;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        h1 {
            color: #2d3748;
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #718096;
            font-size: 1.1em;
        }

        .main-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        @media (max-width: 768px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
        }

        .card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .card h2 {
            color: #2d3748;
            margin-bottom: 20px;
            font-size: 1.5em;
            border-bottom: 3px solid #667eea;
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #4a5568;
            font-weight: 600;
        }

        input[type="file"] {
            width: 100%;
            padding: 12px;
            border: 2px dashed #cbd5e0;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }

        input[type="file"]:hover {
            border-color: #667eea;
            background: #f7fafc;
        }

        textarea {
            width: 100%;
            min-height: 300px;
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            resize: vertical;
            transition: border-color 0.3s;
        }

        textarea:focus {
            outline: none;
            border-color: #667eea;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 1.1em;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            width: 100%;
            font-weight: 600;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .error-message {
            background: #fed7d7;
            color: #c53030;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #fc8181;
        }

        /* Results Styling */
        .score-circle {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            position: relative;
            background: conic-gradient(
                from 0deg,
                #48bb78 0deg,
                #48bb78 calc(var(--score) * 3.6deg),
                #e2e8f0 calc(var(--score) * 3.6deg),
                #e2e8f0 360deg
            );
        }

        .score-circle::before {
            content: '';
            position: absolute;
            width: 160px;
            height: 160px;
            background: white;
            border-radius: 50%;
        }

        .score-content {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .score-number {
            font-size: 3.5em;
            font-weight: bold;
            color: #2d3748;
        }

        .score-label {
            color: #718096;
            font-size: 0.9em;
        }

        .verdict {
            text-align: center;
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 10px;
            padding: 10px;
            border-radius: 8px;
        }

        .verdict-strong {
            background: #c6f6d5;
            color: #22543d;
        }

        .verdict-competitive {
            background: #bee3f8;
            color: #2a4365;
        }

        .verdict-marginal {
            background: #feebc8;
            color: #744210;
        }

        .verdict-weak {
            background: #fed7d7;
            color: #742a2a;
        }

        .honest-assessment {
            background: #fff5f5;
            border-left: 4px solid #fc8181;
            padding: 20px;
            margin: 20px 0;
            font-style: italic;
            color: #4a5568;
            border-radius: 0 8px 8px 0;
        }

        .breakdown-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .breakdown-item {
            background: #f7fafc;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }

        .breakdown-score {
            font-size: 2em;
            font-weight: bold;
            color: #667eea;
        }

        .breakdown-label {
            color: #718096;
            font-size: 0.9em;
            margin-top: 5px;
        }

        .section-title {
            color: #2d3748;
            margin: 30px 0 15px;
            font-size: 1.3em;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title::before {
            content: '';
            width: 4px;
            height: 25px;
            background: #667eea;
            border-radius: 2px;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 15px;
        }

        .skill-card {
            background: #f0fff4;
            border: 1px solid #9ae6b4;
            border-radius: 8px;
            padding: 15px;
            position: relative;
        }

        .skill-card.missing {
            background: #fff5f5;
            border-color: #fc8181;
        }

        .skill-card.important {
            background: #ebf8ff;
            border-color: #90cdf4;
        }

        .skill-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .skill-name {
            font-weight: bold;
            color: #2d3748;
        }

        .skill-badge {
            font-size: 0.75em;
            padding: 3px 8px;
            border-radius: 12px;
            font-weight: 600;
        }

        .badge-critical {
            background: #fc8181;
            color: white;
        }

        .badge-important {
            background: #f6ad55;
            color: white;
        }

        .badge-nice {
            background: #68d391;
            color: white;
        }

        .skill-context {
            font-size: 0.85em;
            color: #4a5568;
            margin-top: 8px;
            padding: 8px;
            background: rgba(255,255,255,0.5);
            border-radius: 4px;
            font-family: monospace;
        }

        .issues-list {
            list-style: none;
        }

        .issue-item {
            background: #fff5f5;
            border-left: 4px solid #fc8181;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 0 8px 8px 0;
        }

        .issue-item.warning {
            background: #fffaf0;
            border-left-color: #ed8936;
        }

        .issue-item.info {
            background: #ebf8ff;
            border-left-color: #4299e1;
        }

        .issue-severity {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75em;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .severity-critical {
            background: #fc8181;
            color: white;
        }

        .severity-high {
            background: #f6ad55;
            color: white;
        }

        .severity-medium {
            background: #f6e05e;
            color: #744210;
        }

        .severity-low {
            background: #68d391;
            color: white;
        }

        .issue-title {
            font-weight: bold;
            color: #742a2a;
            margin-bottom: 5px;
        }

        .issue-impact {
            color: #718096;
            font-size: 0.9em;
            margin-bottom: 5px;
        }

        .issue-fix {
            color: #2f855a;
            font-size: 0.9em;
            font-weight: 600;
        }

        .action-items {
            list-style: none;
            counter-reset: action-counter;
        }

        .action-item {
            counter-increment: action-counter;
            position: relative;
            padding-left: 50px;
            margin-bottom: 20px;
            background: #f7fafc;
            padding: 20px 20px 20px 60px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }

        .action-item::before {
            content: counter(action-counter);
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            width: 30px;
            height: 30px;
            background: #667eea;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .action-priority {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 4px;
            font-size: 0.8em;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .priority-urgent {
            background: #fc8181;
            color: white;
        }

        .priority-high {
            background: #f6ad55;
            color: white;
        }

        .priority-medium {
            background: #68d391;
            color: white;
        }

        .no-results {
            text-align: center;
            padding: 60px 20px;
            color: #718096;
        }

        .no-results-icon {
            font-size: 4em;
            margin-bottom: 20px;
        }

        .highlight {
            background: #fef3c7;
            padding: 2px 4px;
            border-radius: 3px;
            font-weight: bold;
        }

        .experience-box {
            background: #f7fafc;
            padding: 20px;
            border-radius: 8px;
            margin: 15px 0;
        }

        .experience-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e2e8f0;
        }

        .experience-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .nav-links {
            margin-top: 20px;
        }

        .nav-links a {
            color: #667eea;
            text-decoration: none;
            margin-right: 20px;
            font-weight: 600;
        }

        .nav-links a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🎯 ATS Resume Analyzer</h1>
            <p class="subtitle">Brutally honest AI analysis of your CV against job descriptions</p>
            <div class="nav-links">
                <a href="/applications/dashboard">← Back to Dashboard</a>
                <a href="/applications/ai-analytics">View AI Analytics</a>
            </div>
        </header>

        <% if (error) { %>
            <div class="error-message">
                <%= error %>
            </div>
        <% } %>

        <% if (!result) { %>
            <!-- Input Form -->
            <div class="main-grid">
                <div class="card">
                    <h2>Upload Your CV</h2>
                    <form action="/ats/analyze" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="cv">Resume File (PDF, DOC, DOCX)</label>
                            <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="job_description">Job Description</label>
                            <textarea 
                                id="job_description" 
                                name="job_description" 
                                placeholder="Paste the full job description here. The more detail you provide, the more accurate the analysis will be..."
                                required
                            ></textarea>
                        </div>
                        
                        <button type="submit" class="btn-primary">
                            🔍 Analyze My Resume
                        </button>
                    </form>
                </div>

                <div class="card">
                    <h2>How It Works</h2>
                    <p style="margin-bottom: 15px; line-height: 1.6; color: #4a5568;">
                        Our AI analyzes your CV against the job description using the same techniques as modern Applicant Tracking Systems (ATS).
                    </p>
                    
                    <h3 style="margin: 20px 0 10px; color: #2d3748;">What You'll Get:</h3>
                    <ul style="line-height: 2; color: #4a5568; margin-left: 20px;">
                        <li>Accurate ATS compatibility score (0-100)</li>
                        <li>Missing critical skills detection</li>
                        <li>Keyword matching analysis</li>
                        <li>Formatting issue detection</li>
                        <li>Experience requirement matching</li>
                        <li>Brutally honest improvement recommendations</li>
                    </ul>

                    <div style="background: #fffaf0; padding: 15px; border-radius: 8px; margin-top: 20px; border-left: 4px solid #ed8936;">
                        <strong>⚠️ Note:</strong> This analysis is designed to be honest and realistic. A low score doesn't mean you're unqualified—it means your resume needs optimization to pass automated screening.
                    </div>
                </div>
            </div>
        <% } else { %>
            <!-- Results Display -->
            <div class="card" style="margin-bottom: 30px;">
                <div class="score-circle" style="--score: <%= result.ats_score %>">
                    <div class="score-content">
                        <div class="score-number"><%= result.ats_score %></div>
                        <div class="score-label">ATS Score</div>
                    </div>
                </div>

                <div class="verdict verdict-<%= result.feedback.overall_verdict.toLowerCase().split(' ')[0] %>">
                    <%= result.feedback.overall_verdict %>
                </div>

                <div class="honest-assessment">
                    "<%= result.feedback.honest_assessment %>"
                </div>

                <div class="breakdown-grid">
                    <div class="breakdown-item">
                        <div class="breakdown-score"><%= result.breakdown.keyword_match %>%</div>
                        <div class="breakdown-label">Keyword Match</div>
                    </div>
                    <div class="breakdown-item">
                        <div class="breakdown-score"><%= result.breakdown.experience_match.score %>%</div>
                        <div class="breakdown-label">Experience Match</div>
                    </div>
                    <div class="breakdown-item">
                        <div class="breakdown-score"><%= result.breakdown.formatting_score %>%</div>
                        <div class="breakdown-label">Formatting</div>
                    </div>
                    <div class="breakdown-item">
                        <div class="breakdown-score"><%= result.breakdown.critical_skills_coverage %>%</div>
                        <div class="breakdown-label">Critical Skills</div>
                    </div>
                </div>
            </div>

            <!-- Experience Analysis -->
            <div class="card" style="margin-bottom: 30px;">
                <h2 class="section-title">Experience Analysis</h2>
                <div class="experience-box">
                    <div class="experience-row">
                        <span>Required Experience:</span>
                        <strong><%= result.breakdown.experience_match.required_years || 'Not specified' %> years</strong>
                    </div>
                    <div class="experience-row">
                        <span>Your Stated Experience:</span>
                        <strong><%= result.breakdown.experience_match.your_years || 'Not found' %> years</strong>
                    </div>
                    <div class="experience-row">
                        <span>Match Assessment:</span>
                        <strong><%= result.breakdown.experience_match.verdict %></strong>
                    </div>
                </div>
                <% if (result.breakdown.experience_match.recommendation) { %>
                    <div style="background: #fffaf0; padding: 15px; border-radius: 8px; margin-top: 15px;">
                        💡 <%= result.breakdown.experience_match.recommendation %>
                    </div>
                <% } %>
            </div>

            <!-- Matching Strengths -->
            <% if (result.matching_strengths && result.matching_strengths.length > 0) { %>
                <div class="card" style="margin-bottom: 30px;">
                    <h2 class="section-title">✅ Your Matching Strengths</h2>
                    <p style="margin-bottom: 15px; color: #718096;">
                        These skills and keywords from the job description were found in your CV:
                    </p>
                    <div class="skills-grid">
                        <% result.matching_strengths.forEach(function(skill) { %>
                            <div class="skill-card <%= skill.importance === 'critical' ? '' : 'important' %>">
                                <div class="skill-header">
                                    <span class="skill-name"><%= skill.skill %></span>
                                    <span class="skill-badge badge-<%= skill.importance === 'critical' ? 'critical' : skill.importance === 'important' ? 'important' : 'nice' %>">
                                        <%= skill.importance %>
                                    </span>
                                </div>
                                <div style="font-size: 0.85em; color: #718096;">
                                    Category: <%= skill.category %> | 
                                    Found <%= skill.cv_mentions %> time<%= skill.cv_mentions > 1 ? 's' : '' %> in CV
                                </div>
                                <% if (skill.context) { %>
                                    <div class="skill-context">
                                        <%- skill.context.replace(/\*\*(.*?)\*\*/g, '<span class="highlight">$1</span>') %>
                                    </div>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } %>

            <!-- Missing Critical Skills -->
            <% if (result.missing_critical && result.missing_critical.length > 0) { %>
                <div class="card" style="margin-bottom: 30px;">
                    <h2 class="section-title">❌ Missing Critical Skills</h2>
                    <p style="margin-bottom: 15px; color: #718096;">
                        These important requirements from the job description were <strong>not found</strong> in your CV:
                    </p>
                    <div class="skills-grid">
                        <% result.missing_critical.forEach(function(skill) { %>
                            <div class="skill-card missing">
                                <div class="skill-header">
                                    <span class="skill-name"><%= skill.skill %></span>
                                    <span class="skill-badge badge-critical"><%= skill.importance %></span>
                                </div>
                                <div style="font-size: 0.85em; color: #718096; margin-bottom: 8px;">
                                    Category: <%= skill.category %>
                                </div>
                                <div style="font-size: 0.9em; color: #c53030; font-weight: 600;">
                                    💡 <%= skill.suggestion %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } %>

            <!-- Formatting Issues -->
            <% if (result.formatting_issues && result.formatting_issues.length > 0) { %>
                <div class="card" style="margin-bottom: 30px;">
                    <h2 class="section-title">⚠️ Formatting & Parsing Issues</h2>
                    <p style="margin-bottom: 15px; color: #718096;">
                        These issues may prevent ATS systems from reading your CV correctly:
                    </p>
                    <ul class="issues-list">
                        <% result.formatting_issues.forEach(function(issue) { %>
                            <li class="issue-item <%= issue.severity === 'critical' ? '' : issue.severity === 'high' ? 'warning' : 'info' %>">
                                <span class="issue-severity severity-<%= issue.severity %>"><%= issue.severity.toUpperCase() %></span>
                                <div class="issue-title"><%= issue.issue %></div>
                                <div class="issue-impact">Impact: <%= issue.impact %></div>
                                <div class="issue-fix">Fix: <%= issue.fix %></div>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <!-- Action Items -->
            <% if (result.feedback.action_items && result.feedback.action_items.length > 0) { %>
                <div class="card" style="margin-bottom: 30px;">
                    <h2 class="section-title">🎯 Priority Action Items</h2>
                    <ol class="action-items">
                        <% result.feedback.action_items.forEach(function(item) { %>
                            <li class="action-item">
                                <span class="action-priority priority-<%= item.priority.toLowerCase() %>"><%= item.priority %></span>
                                <div style="font-weight: 600; color: #2d3748;"><%= item.action %></div>
                            </li>
                        <% }); %>
                    </ol>
                </div>
            <% } %>

            <!-- Summary Lists -->
            <div class="main-grid">
                <% if (result.feedback.strengths_summary && result.feedback.strengths_summary.length > 0) { %>
                    <div class="card">
                        <h3 style="color: #22543d; margin-bottom: 15px;">✓ What's Working</h3>
                        <ul style="line-height: 2; color: #4a5568;">
                            <% result.feedback.strengths_summary.forEach(function(strength) { %>
                                <li><%= strength %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>

                <% if (result.feedback.weaknesses_summary && result.feedback.weaknesses_summary.length > 0) { %>
                    <div class="card">
                        <h3 style="color: #742a2a; margin-bottom: 15px;">✗ What Needs Work</h3>
                        <ul style="line-height: 2; color: #4a5568;">
                            <% result.feedback.weaknesses_summary.forEach(function(weakness) { %>
                                <li><%= weakness %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>
            </div>

            <div style="text-align: center; margin-top: 30px;">
                <a href="/ats" class="btn-primary" style="display: inline-block; width: auto; text-decoration: none;">
                    Analyze Another Resume
                </a>
            </div>
        <% } %>
    </div>
</body>
</html>