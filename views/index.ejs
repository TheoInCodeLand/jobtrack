    <script>
        // Register GSAP plugins
        gsap.registerPlugin(ScrollTrigger);
        
        // Navigation scroll effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 100) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        }, { passive: true });
        
        // Hero animations
        window.addEventListener('load', () => {
            const tl = gsap.timeline();
            
            tl.to('#hero-line1', {
                y: 0,
                duration: 0.8,
                ease: 'power3.out'
            })
            .to('#hero-line2', {
                y: 0,
                duration: 0.8,
                ease: 'power3.out'
            }, '-=0.6')
            .to('#hero-label', {
                opacity: 1,
                duration: 0.6
            }, '-=0.4')
            .to('#hero-desc', {
                opacity: 1,
                duration: 0.6
            }, '-=0.4')
            .to('#hero-cta', {
                opacity: 1,
                duration: 0.6
            }, '-=0.4');
            
            // Scramble text effect
            const scrambleWords = ['create', 'build', 'scale'];
            let currentIndex = 0;
            const scrambleElement = document.getElementById('scramble-word');
            
            setInterval(() => {
                currentIndex = (currentIndex + 1) % scrambleWords.length;
                gsap.to(scrambleElement, {
                    opacity: 0,
                    filter: 'blur(10px)',
                    duration: 0.2,
                    onComplete: () => {
                        scrambleElement.textContent = scrambleWords[currentIndex];
                        gsap.to(scrambleElement, {
                            opacity: 1,
                            filter: 'blur(0px)',
                            duration: 0.3
                        });
                    }
                });
            }, 3000);
        });
        
        // Hero Canvas Animation (Particle Network)
        const heroCanvas = document.getElementById('hero-canvas');
        const heroCtx = heroCanvas.getContext('2d');
        let heroParticles = [];
        
        function resizeHeroCanvas() {
            heroCanvas.width = heroCanvas.offsetWidth;
            heroCanvas.height = heroCanvas.offsetHeight;
        }
        resizeHeroCanvas();
        window.addEventListener('resize', resizeHeroCanvas);
        
        class Particle {
            constructor() {
                this.reset();
            }
            
            reset() {
                this.x = Math.random() * heroCanvas.width;
                this.y = Math.random() * heroCanvas.height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 2 + 1;
                this.opacity = Math.random() * 0.5 + 0.2;
            }
            
            update() {
                this.x += this.vx;
                this.y += this.vy;
                
                if (this.x < 0 || this.x > heroCanvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > heroCanvas.height) this.vy *= -1;
            }
            
            draw() {
                heroCtx.fillStyle = `rgba(100, 100, 100, ${this.opacity})`;
                heroCtx.fillRect(this.x, this.y, this.size, this.size * 3);
            }
        }
        
        for (let i = 0; i < 80; i++) {
            heroParticles.push(new Particle());
        }
        
        function animateHero() {
            heroCtx.clearRect(0, 0, heroCanvas.width, heroCanvas.height);
            
            heroParticles.forEach(p => {
                p.update();
                p.draw();
            });
            
            // Draw connections
            heroParticles.forEach((p1, i) => {
                heroParticles.slice(i + 1).forEach(p2 => {
                    const dx = p1.x - p2.x;
                    const dy = p1.y - p2.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    
                    if (dist < 100) {
                        heroCtx.strokeStyle = `rgba(150, 150, 150, ${0.1 * (1 - dist / 100)})`;
                        heroCtx.lineWidth = 1;
                        heroCtx.beginPath();
                        heroCtx.moveTo(p1.x, p1.y);
                        heroCtx.lineTo(p2.x, p2.y);
                        heroCtx.stroke();
                    }
                });
            });
            
            requestAnimationFrame(animateHero);
        }
        animateHero();
        
        // Process section interaction
        const processSteps = document.querySelectorAll('.process-step');
        const codeSnippets = {
            1: `<div class="code-line"><span class="text-purple-400">import</span> { optimus } <span class="text-purple-400">from</span> <span class="text-green-400">'@optimus/core'</span></div>
<div class="code-line"></div>
<div class="code-line"><span class="text-blue-400">optimus</span>.<span class="text-yellow-400">connect</span>({</div>
<div class="code-line">&nbsp;&nbsp;source: <span class="text-green-400">'your-database'</span>,</div>
<div class="code-line">&nbsp;&nbsp;sync: <span class="text-orange-400">true</span></div>
<div class="code-line">})</div>`,
            2: `<div class="code-line"><span class="text-blue-400">optimus</span>.<span class="text-yellow-400">workflow</span>(<span class="text-green-400">'process'</span>, {</div>
<div class="code-line">&nbsp;&nbsp;trigger: <span class="text-green-400">'event'</span>,</div>
<div class="code-line">&nbsp;&nbsp;actions: [</div>
<div class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-green-400">'validate'</span>,</div>
<div class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-green-400">'transform'</span>,</div>
<div class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-green-400">'deliver'</span></div>
<div class="code-line">&nbsp;&nbsp;]</div>
<div class="code-line">})</div>`,
            3: `<div class="code-line"><span class="text-purple-400">const</span> app = <span class="text-purple-400">await</span> <span class="text-blue-400">optimus</span>.<span class="text-yellow-400">deploy</span>({</div>
<div class="code-line">&nbsp;&nbsp;name: <span class="text-green-400">'my-app'</span>,</div>
<div class="code-line">&nbsp;&nbsp;region: <span class="text-green-400">'auto'</span>,</div>
<div class="code-line">&nbsp;&nbsp;scaling: {</div>
<div class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;min: <span class="text-orange-400">1</span>,</div>
<div class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;max: <span class="text-orange-400">100</span></div>
<div class="code-line">&nbsp;&nbsp;}</div>
<div class="code-line">})</div>
<div class="code-line"></div>
<div class="code-line">console.<span class="text-yellow-400">log</span>(<span class="text-green-400">'Live at:'</span>, app.url)</div>`
        };
        
        processSteps.forEach(step => {
            step.addEventListener('click', () => {
                const stepNum = step.dataset.step;
                
                // Update progress bars
                document.querySelectorAll('.progress-fill').forEach((bar, idx) => {
                    if (idx < stepNum) {
                        bar.style.width = '100%';
                    } else {
                        bar.style.width = '0%';
                    }
                });
                
                // Update text colors
                processSteps.forEach((s, idx) => {
                    const heading = s.querySelector('h3');
                    if (idx < stepNum) {
                        heading.classList.remove('text-gray-500');
                        heading.classList.add('text-white');
                    } else {
                        heading.classList.add('text-gray-500');
                        heading.classList.remove('text-white');
                    }
                });
                
                // Update code
                document.getElementById('code-content').innerHTML = codeSnippets[stepNum];
            });
        });
        
        // Initialize first step
        document.getElementById('progress-1').style.width = '100%';
        
        // Live metrics update
        function updateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-US', { hour12: true, hour: '2-digit', minute: '2-digit', second: '2-digit' });
            document.getElementById('live-time').textContent = timeStr;
        }
        setInterval(updateTime, 1000);
        updateTime();
        
        // Update request count
        let requestCount = 2847392;
        setInterval(() => {
            requestCount += Math.floor(Math.random() * 50);
            document.getElementById('metric-requests').textContent = requestCount.toLocaleString();
        }, 2000);
        
        // Developer tabs
        const devTabs = document.querySelectorAll('.dev-tab');
        const devCode = document.getElementById('dev-code');
        
        const devSnippets = {
            install: `<div class="text-gray-800">npm install @optimus/sdk</div>
<div class="text-gray-500 mt-4"># or</div>
<div class="text-gray-800 mt-4">yarn add @optimus/sdk</div>
<div class="text-gray-800 mt-2">pnpm add @optimus/sdk</div>`,
            init: `<div class="text-purple-400">import</div> { Optimus } <div class="text-purple-400">from</div> <div class="text-green-400">'@optimus/sdk'</div>
<div class="text-gray-500 mt-4"></div>
<div class="text-purple-400">const</div> optimus = <div class="text-purple-400">new</div> Optimus({</div>
<div>&nbsp;&nbsp;apiKey: process.env.OPTIMUS_KEY</div>
<div>})</div>`,
            deploy: `<div class="text-purple-400">const</div> app = <div class="text-purple-400">await</div> optimus.deploy({</div>
<div>&nbsp;&nbsp;name: <div class="text-green-400">'my-app'</div>,</div>
<div>&nbsp;&nbsp;region: <div class="text-green-400">'auto'</div>,</div>
<div>&nbsp;&nbsp;scaling: {</div>
<div>&nbsp;&nbsp;&nbsp;&nbsp;min: <div class="text-orange-400">1</div>,</div>
<div>&nbsp;&nbsp;&nbsp;&nbsp;max: <div class="text-orange-400">100</div></div>
<div>&nbsp;&nbsp;}</div>
<div>})</div>
<div class="text-gray-500 mt-2"></div>
<div>console.log(<div class="text-green-400">'Live at:'</div>, app.url)</div>`
        };
        
        devTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                devTabs.forEach(t => {
                    t.classList.remove('border-black', 'text-black');
                    t.classList.add('border-transparent', 'text-gray-500');
                });
                tab.classList.remove('border-transparent', 'text-gray-500');
                tab.classList.add('border-black', 'text-black');
                
                const tabName = tab.dataset.tab;
                devCode.innerHTML = devSnippets[tabName];
            });
        });
        
        // Testimonial slider
        const slides = document.querySelectorAll('.testimonial-slide');
        const dots = document.querySelectorAll('#testimonial-dots button');
        const currentSlideEl = document.getElementById('current-slide');
        let currentSlide = 0;
        
        function showSlide(index) {
            slides.forEach((slide, i) => {
                slide.classList.remove('active');
                dots[i].classList.remove('bg-black');
                dots[i].classList.add('bg-gray-300');
            });
            
            slides[index].classList.add('active');
            dots[index].classList.remove('bg-gray-300');
            dots[index].classList.add('bg-black');
            currentSlideEl.textContent = String(index + 1).padStart(2, '0');
        }
        
        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                currentSlide = index;
                showSlide(currentSlide);
            });
        });
        
        setInterval(() => {
            currentSlide = (currentSlide + 1) % slides.length;
            showSlide(currentSlide);
        }, 5000);
        
        // Pricing toggle
        const pricingToggle = document.getElementById('pricing-toggle');
        const proPrice = document.getElementById('pro-price');
        let isAnnual = false;
        
        pricingToggle.addEventListener('click', () => {
            isAnnual = !isAnnual;
            pricingToggle.classList.toggle('active');
            
            if (isAnnual) {
                proPrice.textContent = '$29';
            } else {
                proPrice.textContent = '$24';
            }
        });
        
        // CTA Canvas
        const ctaCanvas = document.getElementById('cta-canvas');
        const ctaCtx = ctaCanvas.getContext('2d');
        let ctaParticles = [];
        
        function resizeCtaCanvas() {
            ctaCanvas.width = ctaCanvas.offsetWidth;
            ctaCanvas.height = ctaCanvas.offsetHeight;
        }
        resizeCtaCanvas();
        window.addEventListener('resize', resizeCtaCanvas);
        
        class CtaParticle {
            constructor() {
                this.reset();
            }
            
            reset() {
                this.x = Math.random() * ctaCanvas.width;
                this.y = Math.random() * ctaCanvas.height;
                this.vx = (Math.random() - 0.5) * 0.3;
                this.vy = (Math.random() - 0.5) * 0.3;
                this.size = Math.random() * 3 + 2;
            }
            
            update() {
                this.x += this.vx;
                this.y += this.vy;
                
                if (this.x < 0 || this.x > ctaCanvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > ctaCanvas.height) this.vy *= -1;
            }
            
            draw() {
                ctaCtx.fillStyle = 'rgba(100, 100, 100, 0.3)';
                ctaCtx.fillRect(this.x, this.y, this.size, this.size * 4);
            }
        }
        
        for (let i = 0; i < 60; i++) {
            ctaParticles.push(new CtaParticle());
        }
        
        function animateCta() {
            ctaCtx.clearRect(0, 0, ctaCanvas.width, ctaCanvas.height);
            
            ctaParticles.forEach(p => {
                p.update();
                p.draw();
            });
            
            requestAnimationFrame(animateCta);
        }
        animateCta();
        
        // Scroll animations
        gsap.utils.toArray('.feature-card').forEach((card, i) => {
            gsap.from(card, {
                scrollTrigger: {
                    trigger: card,
                    start: 'top 80%',
                    toggleActions: 'play none none reverse'
                },
                y: 30,
                opacity: 0,
                duration: 0.6,
                delay: i * 0.1
            });
        });
        
        // Parallax effect for hero canvas
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            heroCanvas.style.transform = `translateY(${scrolled * 0.5}px)`;
        }, { passive: true });
    </script>
</body>
</html>