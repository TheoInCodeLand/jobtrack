<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register - Job Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light d-flex align-items-center py-5" style="min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-5">
                        <h2 class="text-center mb-4 text-success">Create an Account</h2>
                        
                        <% if (locals.error) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= error %>
                            </div>
                        <% } %>

                        <form action="/auth/register" method="POST">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold">Full Name</label>
                                    <input type="text" name="full_name" class="form-control p-2" required placeholder="John Doe">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Email Address</label>
                                    <input type="email" name="email" class="form-control p-2" required placeholder="name@example.com">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Password</label>
                                    <input type="password" name="password" class="form-control p-2" required placeholder="••••••••">
                                </div>
                                
                                <hr class="my-4 text-muted">
                                <h5 class="mb-3 text-secondary">Professional Profile</h5>

                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold">Career Goal / Target Role</label>
                                    <input type="text" name="career_goal" class="form-control p-2" placeholder="e.g., Full Stack Developer">
                                </div>
                                <div class="col-md-8 mb-3">
                                    <label class="form-label fw-bold">Institution (University/College)</label>
                                    <input type="text" name="institution" class="form-control p-2" placeholder="e.g., University of Mpumalanga">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Graduation Year</label>
                                    <input type="number" name="graduation_year" class="form-control p-2" min="1900" max="2100" placeholder="2026">
                                </div>
                            </div>
                            
                            <button type="submit" class="btn btn-success w-100 p-2 mt-3 fw-bold">Register & Continue</button>
                        </form>
                        
                        <div class="text-center mt-4">
                            <p class="text-muted">Already have an account? <a href="/auth/login" class="text-decoration-none">Login here</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>