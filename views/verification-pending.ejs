<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email - Jobtrack</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #171717;
      --foreground: #171717;
      --muted-foreground: #737373;
      --border: #e5e5e5;
      --background: #ffffff;
      --radius: 8px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--background);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 32px;
    }

    .container {
      max-width: 480px;
      width: 100%;
      text-align: center;
    }

    .icon {
      width: 64px;
      height: 64px;
      background-color: #f5f5f5;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
    }

    .icon svg {
      width: 32px;
      height: 32px;
      color: var(--primary);
    }

    h1 {
      font-size: 24px;
      font-weight: 500;
      color: var(--foreground);
      margin-bottom: 16px;
    }

    p {
      font-size: 16px;
      color: var(--muted-foreground);
      line-height: 1.6;
      margin-bottom: 24px;
    }

    .email-box {
      background-color: #f5f5f5;
      padding: 16px;
      border-radius: var(--radius);
      font-size: 16px;
      color: var(--foreground);
      margin-bottom: 32px;
      word-break: break-all;
    }

    .actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .btn-primary {
      width: 100%;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 500;
      color: #ffffff;
      background-color: var(--primary);
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    .btn-primary:hover {
      opacity: 0.9;
    }

    .btn-secondary {
      width: 100%;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 500;
      color: var(--foreground);
      background-color: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.2s ease;
    }

    .btn-secondary:hover {
      background-color: #f9f9f9;
    }

    .alert {
      padding: 12px 16px;
      border-radius: var(--radius);
      margin-bottom: 24px;
      font-size: 14px;
    }

    .alert-error {
      background-color: #fef2f2;
      color: #dc2626;
      border: 1px solid #fecaca;
    }

    .alert-success {
      background-color: #f0fdf4;
      color: #16a34a;
      border: 1px solid #bbf7d0;
    }

    .help-text {
      margin-top: 32px;
      font-size: 14px;
      color: var(--muted-foreground);
    }

    .help-text a {
      color: var(--primary);
      text-decoration: none;
    }

    .help-text a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
    </div>

    <h1>Verify your email</h1>
    
    <p>We've sent a verification link to:</p>
    
    <div class="email-box"><%= email %></div>
    
    <p>Click the link in the email to activate your account. If you don't see it, check your spam folder.</p>

    <% if (locals.error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (locals.message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <div class="actions">
      <form action="/auth/resend-verification" method="POST" style="display: contents;">
        <input type="hidden" name="email" value="<%= email %>">
        <button type="submit" class="btn-secondary">Resend Verification Email</button>
      </form>
      
      <a href="/auth/login" class="btn-primary">Back to Login</a>
    </div>

    <p class="help-text">
      Wrong email? <a href="/auth/register">Create a new account</a>
    </p>
  </div>
</body>
</html>