<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Analytics | Optimus Job Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .stat-card { border-left: 4px solid; }
        .stat-primary { border-color: #0d6efd; }
        .stat-success { border-color: #198754; }
        .stat-warning { border-color: #ffc107; }
        .stat-danger { border-color: #dc3545; }
    </style>
</head>
<body class="bg-light">
    
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/applications/dashboard">
                <i class="bi bi-briefcase-fill"></i> trackForward
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-light">Welcome, <strong><%= user %></strong></span>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary">Application Analytics</h2>
            <a href="/applications/dashboard" class="btn btn-outline-secondary">← Back to Dashboard</a>
        </div>

        <!-- Key Metrics -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card stat-card stat-primary h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase">Avg Response Time</h6>
                        <h3 class="mb-0"><%= Math.round(avgResponseTime) %> days</h3>
                        <small class="text-muted">From apply to first response</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card stat-success h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase">Best Performing Channel</h6>
                        <% const best = methodStats.sort((a,b) => b.positive - a.positive)[0]; %>
                        <h3 class="mb-0"><%= best ? best.app_method : 'N/A' %></h3>
                        <small class="text-muted"><%= best ? Math.round((best.positive/best.total)*100) : 0 %>% success rate</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card stat-warning h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase">Total In Pipeline</h6>
                        <% const active = methodStats.reduce((acc, m) => acc + parseInt(m.total), 0); %>
                        <h3 class="mb-0"><%= active %></h3>
                        <small class="text-muted">Active applications</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card stat-danger h-100">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase">Total Offers</h6>
                        <% const offers = methodStats.reduce((acc, m) => acc + parseInt(m.offers), 0); %>
                        <h3 class="mb-0"><%= offers %></h3>
                        <small class="text-muted">Offer received rate</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Method Performance Table -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 fw-bold">Performance by Channel</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Channel</th>
                                        <th>Total</th>
                                        <th>Interviews</th>
                                        <th>Offers</th>
                                        <th>Success %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% methodStats.forEach(method => { 
                                        const rate = method.total > 0 ? Math.round((method.positive/method.total)*100) : 0;
                                    %>
                                    <tr>
                                        <td><%= method.app_method %></td>
                                        <td><%= method.total %></td>
                                        <td><%= method.positive %></td>
                                        <td><%= method.offers %></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                                    <div class="progress-bar bg-success" style="width: <%= rate %>%"></div>
                                                </div>
                                                <span class="small"><%= rate %>%</span>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Monthly Trend Chart -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 fw-bold">Application Trend (6 Months)</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Insights -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightbulb"></i> Insights</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <% if (avgResponseTime > 14) { %>
                    <li class="list-group-item">
                        <i class="bi bi-clock-history text-warning"></i> 
                        <strong>Response time is <%= Math.round(avgResponseTime) %> days</strong> — consider following up after 10-14 days
                    </li>
                    <% } %>
                    <% if (best && best.app_method) { %>
                    <li class="list-group-item">
                        <i class="bi bi-trophy text-success"></i> 
                        <strong><%= best.app_method %></strong> is your best channel — prioritize this method
                    </li>
                    <% } %>
                    <% if (offers === 0 && active > 10) { %>
                    <li class="list-group-item">
                        <i class="bi bi-exclamation-triangle text-danger"></i> 
                        No offers yet from <%= active %> applications — consider reviewing your resume or targeting different roles
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>

    <!-- Replace the script section at the bottom -->
<script>
    const ctx = document.getElementById('trendChart').getContext('2d');
    
    // Parse the monthly data safely
    const rawData = <%- JSON.stringify(monthlyTrend) %>;
    const monthlyData = rawData.map(m => {
        // Handle both Date objects and string formats
        const dateStr = m.month;
        const date = new Date(dateStr);
        return {
            month: date.toLocaleDateString('en-US', { month: 'short', year: '2-digit' }),
            count: parseInt(m.count)
        };
    });
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: monthlyData.map(d => d.month),
            datasets: [{
                label: 'Applications',
                data: monthlyData.map(d => d.count),
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } }
            }
        }
    });
</script>
</body>
</html>